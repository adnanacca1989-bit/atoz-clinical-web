@page
@model AtoZClinical.Web.Pages.Admin.DataPrivacyModel
@{
    ViewData["Title"] = "Data Privacy (GDPR)";
    Layout = "_Layout";
}

<div class="atz-card p-4">
    <h1 class="atz-section-title">Data Privacy</h1>
    <p class="text-muted">Export or permanently delete all data for <strong>@Model.ClinicName</strong>.</p>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <div class="border rounded p-3 mb-4">
        <h2 class="h5">Export clinic data</h2>
        <p class="text-muted">Download a ZIP of Excel files containing your clinic's operational data (patients, invoices, pharmacy, audit log, etc.).</p>
        <form method="post" asp-page-handler="Export">
            <button type="submit" class="btn btn-atz-primary">Download GDPR export (ZIP)</button>
        </form>
    </div>

    <div class="border border-danger rounded p-3">
        <h2 class="h5 text-danger">Delete clinic and all data</h2>
        <p class="text-muted">This permanently removes your clinic, all patients, transactions, users, and settings. This cannot be undone.</p>
        <form method="post" asp-page-handler="Delete" onsubmit="return confirm('Permanently delete all clinic data?');">
            <div class="mb-3">
                <label class="form-label">Type the clinic name to confirm: <strong>@Model.ClinicName</strong></label>
                <input asp-for="ConfirmClinicName" class="form-control" autocomplete="off" />
            </div>
            <button type="submit" class="btn btn-danger">Delete clinic permanently</button>
        </form>
    </div>

    <p class="small text-muted mt-3 mb-0">
        See also <a asp-page="/Legal/Privacy">Privacy Policy</a> and <a asp-page="/Legal/Terms">Terms of Service</a>.
    </p>
</div>
