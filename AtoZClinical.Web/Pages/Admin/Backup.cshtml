@page
@model AtoZClinical.Web.Pages.Admin.BackupModel
@{
    ViewData["Title"] = "Data Backup";
    Layout = "_Layout";
}

<div class="clinical-form-page">
    <h1 class="page-title">Data Backup</h1>
    <p class="text-muted">Export clinic data to Excel files for backup and offline review.</p>
    <p class="small text-muted mb-4">Clinic: <strong>@Model.ClinicName</strong> · @Model.StatusText</p>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="atz-card p-4 h-100">
                <h5>Separate Excel Files (ZIP)</h5>
                <p class="text-muted small">
                    Downloads a ZIP archive containing one Excel file per module:
                    Patients, Doctors, Lab, Radiology, Pharmacy, Invoices, Cash, Chart of Accounts, Audit Log, and more.
                </p>
                <form method="post" asp-page-handler="ExportZip">
                    <button type="submit" class="btn btn-atz-primary">📦 Export Excel Files (ZIP)</button>
                </form>
            </div>
        </div>
        <div class="col-md-6">
            <div class="atz-card p-4 h-100">
                <h5>Single Excel Workbook</h5>
                <p class="text-muted small">
                    Downloads one .xlsx file with multiple sheets for the main clinic data
                    (Patients, Doctors, Pharmacy, Invoices, Cash Receipts, Audit Log).
                </p>
                <form method="post" asp-page-handler="ExportWorkbook">
                    <button type="submit" class="btn btn-outline-primary">📊 Export Workbook (.xlsx)</button>
                </form>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-2">
        <div class="col-md-12">
            <div class="atz-card p-4">
                <h5>Restore from Backup (ZIP)</h5>
                <p class="text-muted small">
                    Upload a ZIP backup file exported from this system. Patients, doctors, and chart of accounts will be imported or updated by ID.
                    Other files in the archive are skipped for safety.
                </p>
                @if (!string.IsNullOrWhiteSpace(Model.RestoreMessage))
                {
                    <div class="alert @(Model.RestoreMessage.StartsWith("Restore complete") ? "alert-success" : "alert-warning")">@Model.RestoreMessage</div>
                }
                <form method="post" asp-page-handler="Restore" enctype="multipart/form-data">
                    <div class="mb-3">
                        <input type="file" name="RestoreFile" class="form-control" accept=".zip" />
                    </div>
                    <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Restore will update matching records in this clinic. Continue?');">📥 Restore from ZIP</button>
                </form>
            </div>
        </div>
    </div>

    <div class="clinical-toolbar mt-4">
        <a asp-page="/Dashboard/Index" class="btn-form text-decoration-none text-dark">✕ Close</a>
    </div>

    <div class="atz-card p-3 mt-4">
        <h5>Backup History</h5>
        @if (Model.History.Count == 0)
        {
            <p class="text-muted mb-0">No backups recorded yet.</p>
        }
        else
        {
            <table class="table table-sm mb-0">
                <thead><tr><th>Date</th><th>Action</th><th>File</th><th>Size</th><th>By</th><th>Notes</th></tr></thead>
                <tbody>
                @foreach (var h in Model.History)
                {
                    <tr>
                        <td>@h.CreatedAt.ToLocalTime().ToString("g")</td>
                        <td>@h.Action</td>
                        <td>@h.FileName</td>
                        <td>@(h.FileSizeBytes / 1024) KB</td>
                        <td>@(h.PerformedBy ?? "—")</td>
                        <td class="small">@(h.Notes ?? "—")</td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>
</div>
