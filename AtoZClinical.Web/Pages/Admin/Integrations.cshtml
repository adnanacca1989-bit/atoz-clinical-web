@page
@model AtoZClinical.Web.Pages.Admin.IntegrationsModel
@using AtoZClinical.Core.Webhooks
@{
    ViewData["Title"] = "Integrations";
    Layout = "_Layout";
}

<h2 class="atz-section-title">API &amp; webhooks</h2>
<p class="text-muted">Connect external systems with REST API keys and outbound webhooks.</p>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-info">@Model.Message</div>
}

@if (!string.IsNullOrEmpty(Model.NewPlainApiKey))
{
    <div class="alert alert-warning">
        <strong>New API key (copy now):</strong>
        <code class="user-select-all">@Model.NewPlainApiKey</code>
        <p class="mb-0 small mt-2">Send as header <code>X-Api-Key</code> or <code>Authorization: Bearer &lt;key&gt;</code></p>
    </div>
}

<div class="row g-4">
    <div class="col-lg-6">
        <div class="atz-card p-3">
            <h5>API keys</h5>
            <p class="small text-muted">Endpoints: <code>GET/POST /api/v1/patients</code>, <code>GET /api/v1/doctors</code>, <code>GET/POST /api/v1/appointments</code>, <code>GET /api/v1/invoices</code>, <code>GET /api/v1/lab-results</code></p>
            <table class="table table-sm">
                <thead><tr><th>Name</th><th>Prefix</th><th>Last used</th><th></th></tr></thead>
                <tbody>
                @foreach (var key in Model.ApiKeys.Where(k => k.IsActive))
                {
                    <tr>
                        <td>@key.Name</td>
                        <td><code>@key.KeyPrefix…</code></td>
                        <td>@(key.LastUsedAt?.ToString("g") ?? "—")</td>
                        <td>
                            <form method="post" asp-page-handler="RevokeKey" class="d-inline">
                                <input type="hidden" name="keyId" value="@key.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Revoke</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
            <form method="post" asp-page-handler="CreateKey" class="mt-3">
                <div class="input-group input-group-sm">
                    <input asp-for="NewKeyName" class="form-control" placeholder="Key name" />
                    <button type="submit" class="btn btn-atz-primary">Create key</button>
                </div>
            </form>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="atz-card p-3">
            <h5>Webhooks</h5>
            <p class="small text-muted">Events: @string.Join(", ", WebhookEvents.All)</p>
            @foreach (var wh in Model.WebhookSubscriptions)
            {
                <div class="border rounded p-2 mb-2 small">
                    <div class="fw-semibold">@wh.TargetUrl</div>
                    <div class="text-muted">@wh.Events · @(wh.IsActive ? "Active" : "Inactive")</div>
                    <form method="post" asp-page-handler="DeleteWebhook" class="mt-1">
                        <input type="hidden" name="webhookId" value="@wh.Id" />
                        <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                    </form>
                </div>
            }
            <form method="post" asp-page-handler="AddWebhook" class="mt-3">
                <div class="mb-2">
                    <input asp-for="WebhookUrl" class="form-control form-control-sm" placeholder="https://example.com/webhooks/atoz" />
                </div>
                <div class="mb-2">
                    <input asp-for="SelectedWebhookEvents" class="form-control form-control-sm" />
                </div>
                <button type="submit" class="btn btn-sm btn-atz-primary">Add webhook</button>
            </form>
        </div>
    </div>
</div>
