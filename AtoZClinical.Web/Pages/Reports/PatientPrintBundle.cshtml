@page
@model AtoZClinical.Web.Pages.Reports.PatientPrintBundleModel
@{
    Layout = "_PrintLayout";
    ViewData["Title"] = "Patient Reports";
}

<div class="print-toolbar-screen no-print">
    <button type="button" class="btn-form btn-form-primary" onclick="window.print();">🖨️ Print All Reports</button>
    <button type="button" class="btn-form" onclick="window.close();">✕ Close</button>
</div>

<partial name="_ReportBranding" />
<partial name="_PatientPrintBundleBody" model="Model.Bundle" />

@section Scripts {
    <script>
        window.addEventListener('load', () => {
            if (@Model.Bundle.Sections.Count > 0) setTimeout(() => window.print(), 400);
        });
    </script>
}
