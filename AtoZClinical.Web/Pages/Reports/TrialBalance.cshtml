@page
@model AtoZClinical.Web.Pages.Reports.TrialBalanceModel
@{
    ViewData["Title"] = "Trial Balance";
    Layout = "_Layout";
}

<div class="clinical-form-page clinical-report-page">
    <h1 class="page-title">Trial Balance</h1>
    <partial name="_ReportBranding" />
    <form method="post" id="clinicalReportForm">
        <button type="submit" asp-page-handler="Run" id="reportRunSubmit" class="d-none" aria-hidden="true"></button>
        <div class="report-filter-panel">
            <div class="row g-2 mb-0">
                <div class="col-md-3">
                    <label class="clinical-field-label">As Of Date</label>
                    <input asp-for="AsOfDate" class="clinical-field" type="date" />
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <div class="form-check mb-2">
                        <input asp-for="NonZeroOnly" class="form-check-input" type="checkbox" id="nonZeroOnlyCheck" />
                        <label class="form-check-label" for="nonZeroOnlyCheck">Show Non-Zero Accounts Only</label>
                    </div>
                </div>
            </div>
        </div>
        <p class="report-hint">Journal trial balance as of the selected date. <strong>Cash &amp; equivalents (Cash + Bank + Visa Card)</strong> matches the Cash Report closing balance and Balance Sheet.</p>
        <div class="report-summary-panel">
            <span><strong>Total Debit:</strong> @Model.TotalDebit.ToString("N2")</span>
            <span><strong>Total Credit:</strong> @Model.TotalCredit.ToString("N2")</span>
            <span><strong>Cash &amp; Equivalents (GL):</strong> @Model.TotalLiquidCash.ToString("N2")</span>
        </div>
        <div class="report-results-scroll">
            <table class="line-grid report-grid">
                <thead>
                    <tr>
                        <th>GL No</th>
                        <th>Category</th>
                        <th>Account</th>
                        <th class="text-end">Debit</th>
                        <th class="text-end">Credit</th>
                        <th class="text-end">Balance</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var r in Model.Results)
                {
                    <tr>
                        <td>@(r.AccountNo > 0 ? r.AccountNo.ToString() : "—")</td>
                        <td>@r.AccountCategory</td>
                        <td>@r.AccountName</td>
                        <td class="text-end">@r.TotalDebit.ToString("N2")</td>
                        <td class="text-end">@r.TotalCredit.ToString("N2")</td>
                        <td class="text-end">@r.Balance.ToString("N2")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <partial name="_ReportToolbar" />
    </form>
</div>
