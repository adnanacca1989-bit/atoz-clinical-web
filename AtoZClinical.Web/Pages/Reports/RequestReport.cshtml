@page
@model AtoZClinical.Web.Pages.Reports.RequestReportModel
@{
    ViewData["Title"] = "Request Report";
    ViewData["UseReportPickers"] = true;
    ViewData["ReportColumnKey"] = "Request Report";
    Layout = "_Layout";
}

<div class="clinical-form-page clinical-report-page">
    <h1 class="page-title">Request Report</h1>
    <partial name="_ReportBranding" />
    <form method="post" id="clinicalReportForm">
        <button type="submit" asp-page-handler="Run" id="reportRunSubmit" class="d-none" aria-hidden="true"></button>
        <div class="report-filter-panel">
            <div class="row g-2 mb-0">
                <div class="col-md-2">
                    <label class="clinical-field-label">From Date</label>
                    <input asp-for="FromDate" class="clinical-field" type="date" />
                </div>
                <div class="col-md-2">
                    <label class="clinical-field-label">To Date</label>
                    <input asp-for="ToDate" class="clinical-field" type="date" />
                </div>
                <div class="col-md-3">
                    <label class="clinical-field-label">Doctor Name</label>
                    <input asp-for="DoctorName" id="reportDoctorNameInput" class="clinical-field doctor-picker-field" readonly placeholder="Click to select doctor..." />
                </div>
                <div class="col-md-3">
                    <label class="clinical-field-label">Patient Name</label>
                    <input asp-for="PatientName" id="reportPatientNameInput" class="clinical-field doctor-picker-field" readonly placeholder="Click to select patient..." />
                </div>
                <div class="col-md-2 d-flex align-items-end gap-3">
                    <div class="form-check">
                        <input asp-for="PendingOnly" class="form-check-input" type="checkbox" />
                        <label class="form-check-label">Pending Only</label>
                    </div>
                    <div class="form-check">
                        <input asp-for="NonZero" class="form-check-input" type="checkbox" />
                        <label class="form-check-label">Non Zero</label>
                    </div>
                </div>
            </div>
        </div>
        <p class="report-hint">
            Showing @Model.Results.Count request(s) for @Model.FromDate.ToString("d") – @Model.ToDate.ToString("d").
            <strong>Created</strong> means a related result, bill, or invoice exists; <strong>Not Yet</strong> means it is still pending.
            Click <strong>Run</strong> after changing filters.
        </p>

        <div id="print-area" class="report-results-scroll">
            <table class="line-grid report-grid request-report-grid">
                <thead>
                    <tr>
                        <th data-col="no">No</th>
                        <th data-col="requestDate">Request Date</th>
                        <th data-col="requestNo">Request No</th>
                        <th data-col="transactionType">Type of Transaction</th>
                        <th data-col="patientId">Patient ID</th>
                        <th data-col="patientName">Patient Name</th>
                        <th data-col="appointmentDate">Appointment Date</th>
                        <th data-col="appointmentTime">Appointment Time</th>
                        <th data-col="age">Age</th>
                        <th data-col="sex">Sex</th>
                        <th data-col="phone">Phone</th>
                        <th data-col="city">City</th>
                        <th data-col="doctorName">Doctor Name</th>
                        <th data-col="specialty">Specialty</th>
                        <th data-col="amountRequest" class="text-end">Amount Request</th>
                        <th data-col="resultInvoice">Result Invoice</th>
                        <th data-col="createdByUser">Created By User</th>
                        <th data-col="resultDate">Result Date</th>
                        <th data-col="resultId">Result ID</th>
                    </tr>
                </thead>
                <tbody>
                @{ var rowNo = 0; }
                @foreach (var r in Model.Results)
                {
                    rowNo++;
                    <tr>
                        <td data-col="no">@rowNo</td>
                        <td data-col="requestDate">@r.RequestDate.ToString("d")</td>
                        <td data-col="requestNo">@r.RequestNo</td>
                        <td data-col="transactionType">@r.TransactionType</td>
                        <td data-col="patientId">@r.PatientId</td>
                        <td data-col="patientName">@r.PatientName</td>
                        <td data-col="appointmentDate">@(r.AppointmentDate?.ToString("d") ?? "")</td>
                        <td data-col="appointmentTime">@RequestReportModel.FormatTime(r.AppointmentTime)</td>
                        <td data-col="age">@(r.Age?.ToString() ?? "")</td>
                        <td data-col="sex">@r.Sex</td>
                        <td data-col="phone">@r.Phone</td>
                        <td data-col="city">@r.City</td>
                        <td data-col="doctorName">@r.DoctorName</td>
                        <td data-col="specialty">@r.Specialty</td>
                        <td data-col="amountRequest" class="text-end">@r.AmountRequest.ToString("N2")</td>
                        <td data-col="resultInvoice" class="@RequestReportModel.StatusCssClass(r.ResultInvoiceStatus)">@r.ResultInvoiceStatus</td>
                        <td data-col="createdByUser">@r.CreatedByUser</td>
                        <td data-col="resultDate">@(r.ResultDate?.ToString("d") ?? "")</td>
                        <td data-col="resultId">
                            @if (r.ResultRecordId.HasValue && !string.IsNullOrWhiteSpace(r.ResultPagePath))
                            {
                                <a href="@Url.Page(r.ResultPagePath, new { RecordId = r.ResultRecordId })">@r.ResultId</a>
                            }
                            else
                            {
                                @r.ResultId
                            }
                        </td>
                    </tr>
                }
                </tbody>
                @if (Model.Results.Count > 0)
                {
                    <tfoot>
                        <tr class="report-totals-row fw-bold">
                            <td data-col="no"></td>
                            <td data-col="requestDate"></td>
                            <td data-col="requestNo"></td>
                            <td data-col="transactionType"></td>
                            <td data-col="patientId"></td>
                            <td data-col="patientName"></td>
                            <td data-col="appointmentDate"></td>
                            <td data-col="appointmentTime"></td>
                            <td data-col="age"></td>
                            <td data-col="sex"></td>
                            <td data-col="phone"></td>
                            <td data-col="city"></td>
                            <td data-col="doctorName">Totals</td>
                            <td data-col="specialty"></td>
                            <td data-col="amountRequest" class="text-end">@Model.TotalAmount.ToString("N2")</td>
                            <td data-col="resultInvoice"></td>
                            <td data-col="createdByUser"></td>
                            <td data-col="resultDate"></td>
                            <td data-col="resultId"></td>
                        </tr>
                    </tfoot>
                }
            </table>
        </div>

        <partial name="_ReportToolbar" />
    </form>
</div>

<partial name="_PatientSelectModal" />
<partial name="_DoctorSelectModal" />

@section Scripts {
    <script src="~/js/patient-picker.js" asp-append-version="true"></script>
    <script src="~/js/doctor-picker.js" asp-append-version="true"></script>
    <script src="~/js/report-filters.js" asp-append-version="true"></script>
    <partial name="_ReportColumnFilterScript" />
    <script>document.addEventListener('DOMContentLoaded', () => initReportPickers());</script>
}
