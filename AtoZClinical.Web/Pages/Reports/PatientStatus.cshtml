@page
@model AtoZClinical.Web.Pages.Reports.PatientStatusModel
@{
    ViewData["Title"] = "Patient Status Report";
    Layout = "_Layout";
    string StatusClass(string status) => status switch
    {
        "Overdue" => "appt-status-overdue",
        "Under Process" => "appt-status-process",
        "Completed" => "appt-status-completed",
        "Cancelled" => "appt-status-cancelled",
        _ => "appt-status-scheduled"
    };
}

<div class="clinical-form-page clinical-report-page clinical-standard-form">
    <h1 class="page-title">Patient Status Report</h1>
    <form method="post" id="clinicalReportForm">
        <div class="report-filter-panel">
        <div class="row g-2 mb-0">
            <div class="col-md-3">
                <label class="clinical-field-label">From Date</label>
                <input asp-for="FromDate" class="clinical-field" type="date" />
            </div>
            <div class="col-md-3">
                <label class="clinical-field-label">To Date</label>
                <input asp-for="ToDate" class="clinical-field" type="date" />
            </div>
            <div class="col-md-3">
                <label class="clinical-field-label">Status</label>
                <select asp-for="Status" class="clinical-field">
                    <option>All</option>
                    <option>Scheduled</option>
                    <option>Under Process</option>
                    <option>Overdue</option>
                    <option>Completed</option>
                    <option>Cancelled</option>
                </select>
            </div>
        </div>
        </div>
        <p class="report-hint">Showing @Model.Results.Count patient status records. Click <strong>Search</strong> or <strong>Run</strong> after changing dates or status.</p>
        <div class="clinical-record-grid">
            <table class="report-grid">
                <thead>
                    <tr><th>No.</th><th>Patient Name</th><th>Appointment Date</th><th>Appointment Time</th><th>Doctor Name</th><th>Specialty</th><th class="text-end">Invoice Balance</th><th>Status</th></tr>
                </thead>
                <tbody>
                @{ var n = 0; }
                @foreach (var r in Model.Results)
                {
                    n++;
                    var timeText = r.AppointmentTime.HasValue
                        ? DateTime.Today.Add(r.AppointmentTime.Value).ToString("h:mm tt")
                        : "";
                    <tr>
                        <td>@n</td>
                        <td>@r.PatientName</td>
                        <td>@(r.AppointmentDate?.ToString("M/d/yyyy") ?? "")</td>
                        <td>@timeText</td>
                        <td>@r.DoctorName</td>
                        <td>@r.Specialty</td>
                        <td class="text-end">@r.InvoiceBalance.ToString("N2")</td>
                        <td><span class="appt-status-pill @StatusClass(r.Status)">@r.Status</span></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <partial name="_ReportToolbar" />
    </form>
</div>
