@page
@using AtoZClinical.Infrastructure.Services
@model AtoZClinical.Web.Pages.Reports.AppointmentRemindersModel
@{
    ViewData["Title"] = "Appointment Reminders";
    ViewData["ReportColumnKey"] = "Appointment Reminders";
    Layout = "_Layout";
    string StatusClass(string status) => PatientVisitStatuses.Normalize(status) switch
    {
        PatientVisitStatuses.Cancelled => "appt-status-cancelled",
        PatientVisitStatuses.Completed => "appt-status-completed",
        PatientVisitStatuses.Confirmed => "appt-status-scheduled",
        PatientVisitStatuses.UnderProcess => "appt-status-process",
        PatientVisitStatuses.Pending => "appt-status-scheduled",
        _ => "appt-status-scheduled"
    };
    string RemainingClass(string status) => PatientVisitStatuses.Normalize(status) == PatientVisitStatuses.Completed
        ? "appt-remaining-active"
        : "appt-remaining-overdue";
}

<div class="clinical-form-page clinical-report-page clinical-standard-form appt-reminders-page">
    <h1 class="page-title">Appointment Reminders</h1>
    <partial name="_ReportBranding" />
    <form method="post">
        <div class="report-filter-panel">
            <div class="row g-2 mb-0">
                <div class="col-md-2">
                    <label class="clinical-field-label">From Date</label>
                    <input asp-for="FromDate" class="clinical-field" type="date" />
                </div>
                <div class="col-md-2">
                    <label class="clinical-field-label">To Date</label>
                    <input asp-for="ToDate" class="clinical-field" type="date" />
                </div>
                <div class="col-md-2">
                    <label class="clinical-field-label">Gender</label>
                    <select asp-for="Gender" class="clinical-field">
                        <option>All</option>
                        <option>Male</option>
                        <option>Female</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="clinical-field-label">Doctor</label>
                    <select asp-for="DoctorName" class="clinical-field">
                        <option>All</option>
                        @foreach (var d in Model.DoctorOptions)
                        {
                            <option value="@d">@d</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="clinical-field-label">Specialty</label>
                    <select asp-for="Specialty" class="clinical-field">
                        <option>All</option>
                        @foreach (var s in Model.SpecialtyOptions)
                        {
                            <option value="@s">@s</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="clinical-field-label">City</label>
                    <select asp-for="City" class="clinical-field">
                        <option>All</option>
                        @foreach (var c in Model.CityOptions)
                        {
                            <option value="@c">@c</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="clinical-field-label">Status</label>
                    <select asp-for="Status" class="clinical-field">
                        <option>All</option>
                        <option>Pending</option>
                        <option>Confirmed</option>
                        <option>Under Process</option>
                        <option>Completed</option>
                        <option>Cancelled</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="clinical-field-label">Patient Search</label>
                    <input asp-for="PatientSearch" class="clinical-field" placeholder="Select patient..." />
                </div>
                <div class="col-md-4 d-flex align-items-end gap-2">
                    <button type="submit" asp-page-handler="Clear" class="btn btn-outline-secondary">Clear</button>
                    <button type="submit" asp-page-handler="Search" class="btn btn-primary">Search</button>
                </div>
            </div>
        </div>

        <h1 class="page-title appt-reminders-title">Appointment Reminders</h1>

        <div class="clinical-record-grid">
            <table class="report-grid appt-reminders-grid">
                <thead>
                    <tr>
                        <th data-col="no">No.</th>
                        <th data-col="patientId">Patient ID</th>
                        <th data-col="patientName">Patient Name</th>
                        <th data-col="mobile">Mobile</th>
                        <th data-col="doctorName">Doctor Name</th>
                        <th data-col="specialty" data-col-default="false">Specialty</th>
                        <th data-col="apptDate">Appt. Date</th>
                        <th data-col="apptTime">Appt. Time</th>
                        <th data-col="rebookTime">Re-Book Appt. Time</th>
                        <th data-col="remainingTime">Remaining Time</th>
                        <th data-col="status">Status</th>
                    </tr>
                </thead>
                <tbody>
                @{ var n = 0; }
                @foreach (var r in Model.Results)
                {
                    n++;
                    var timeText = r.AppointmentTime.HasValue
                        ? DateTime.Today.Add(r.AppointmentTime.Value).ToString("h:mm tt")
                        : "";
                    <tr class="@(r.ShouldNotify ? "appt-row-alert" : "")">
                        <td>@n</td>
                        <td>@r.PatientNo</td>
                        <td>@r.PatientName</td>
                        <td>@r.Mobile</td>
                        <td>@r.DoctorName</td>
                        <td>@r.Specialty</td>
                        <td>@r.AppointmentDate.ToString("M/d/yyyy")</td>
                        <td>@timeText</td>
                        <td>
                            <form method="post" asp-page-handler="AdjustTime" class="d-flex gap-1 align-items-center appt-adjust-form">
                                <input type="hidden" name="patientId" value="@r.PatientId" />
                                <input type="date" name="appointmentDate" class="clinical-field form-control form-control-sm"
                                       value="@r.AppointmentDate.ToString("yyyy-MM-dd")" required />
                                <input type="time" name="appointmentTime" class="clinical-field form-control form-control-sm"
                                       value="@(r.AppointmentTime.HasValue ? $"{r.AppointmentTime.Value.Hours:D2}:{r.AppointmentTime.Value.Minutes:D2}" : "")" />
                                <button type="submit" class="btn btn-sm btn-outline-primary appt-adjust-btn">Save</button>
                            </form>
                        </td>
                        <td><span class="appt-remaining-pill @RemainingClass(r.Status)">@r.RemainingLabel</span></td>
                        <td><span class="appt-status-pill @StatusClass(r.Status)">@r.Status</span></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-3">
            <span class="text-muted">Showing @Model.Results.Count reminders</span>
            <div class="d-flex gap-2 clinical-toolbar p-0 border-0">
                <button type="button" class="btn-form" id="reportColumnFilterBtn">Filter</button>
                <button type="button" class="btn-form" onclick="location.reload()">Refresh</button>
                <a class="btn-form text-decoration-none text-dark" asp-page="/Dashboard/Index">Close</a>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ReportColumnFilterScript" />
    <script src="~/js/appointment-reminders.js" asp-append-version="true"></script>
}
