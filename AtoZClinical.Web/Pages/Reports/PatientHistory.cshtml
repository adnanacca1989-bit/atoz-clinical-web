@page
@model AtoZClinical.Web.Pages.Reports.PatientHistoryModel
@{
    ViewData["Title"] = "Patient History";
    Layout = "_Layout";
}

<div class="clinical-form-page clinical-report-page">
    <h1 class="page-title">Patient History</h1>
    <partial name="_ReportBranding" />
    <form method="post" id="patientHistoryForm">
        <button type="submit" asp-page-handler="Run" id="patientHistoryRunSubmit" class="d-none" aria-hidden="true"></button>
        <div class="report-filter-panel">
        <div class="row g-2 mb-0">
            <div class="col-md-3">
                <label class="clinical-field-label">Patient Name</label>
                <input asp-for="PatientName" id="patientHistoryPatientInput" class="clinical-field doctor-picker-field" readonly placeholder="Click to select patient..." />
            </div>
            <div class="col-md-3">
                <label class="clinical-field-label">Doctor Name</label>
                <input asp-for="DoctorName" id="patientHistoryDoctorInput" class="clinical-field doctor-picker-field" readonly placeholder="Optional — click to filter by doctor..." />
            </div>
            <div class="col-md-2 d-flex align-items-end gap-2 no-print">
                <button type="button" class="btn btn-primary" id="patientHistorySearchPatientBtn">🔍 Search</button>
                <button type="submit" asp-page-handler="Run" class="btn btn-outline-primary">Run</button>
                <button type="submit" asp-page-handler="Clear" class="btn btn-outline-secondary">🧹 Clear</button>
            </div>
            <div class="col-md-2">
                <label class="clinical-field-label">Patient ID / Barcode</label>
                <input asp-for="PatientId" id="patientHistoryPatientIdInput" class="clinical-field patient-barcode-input" placeholder="Scan barcode..." autocomplete="off" />
            </div>
            <div class="col-md-1">
                <label class="clinical-field-label">Age</label>
                <input asp-for="Age" id="patientHistoryAgeInput" class="clinical-field" readonly />
            </div>
            <div class="col-md-2">
                <label class="clinical-field-label">Date of Birth</label>
                <input asp-for="DateOfBirth" id="patientHistoryDobInput" class="clinical-field" readonly />
            </div>
            <div class="col-md-2">
                <label class="clinical-field-label">City</label>
                <input asp-for="City" id="patientHistoryCityInput" class="clinical-field" readonly />
            </div>
            <div class="col-md-3">
                <label class="clinical-field-label">Phone Number</label>
                <input asp-for="PhoneNumber" id="patientHistoryPhoneInput" class="clinical-field" readonly />
            </div>
        </div>
        </div>
        <p class="report-hint">Select a patient (and optional doctor), then click <strong>Run</strong>. Use <strong>Print All Patient Reports</strong> for a full A4 bundle.</p>
        <div class="report-results-scroll">
            <table class="line-grid report-grid">
                <thead><tr><th>Patient</th><th>Form</th><th>Date</th><th>Doctor</th><th>Details</th></tr></thead>
                <tbody>
                @foreach (var r in Model.Results)
                {
                    <tr>
                        <td>@r.Patient</td>
                        <td>@r.Form</td>
                        <td>@r.Date.ToString("d")</td>
                        <td>@r.Doctor</td>
                        <td>@r.Details</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <h2 class="h5 mt-4 mb-2">Accounts Receivable</h2>
        <p class="report-hint">Invoice balances for the selected patient@(string.IsNullOrWhiteSpace(Model.DoctorName) ? "" : " and doctor"). Ending balance uses <strong>Dr</strong> (patient owes) or <strong>Cr</strong> (patient credit).</p>
        <div class="report-results-scroll">
            <table class="line-grid report-grid">
                <thead>
                    <tr>
                        <th>Invoice ID</th>
                        <th>Invoice Date</th>
                        <th>Patient</th>
                        <th>Doctor</th>
                        <th>Specialty</th>
                        <th>Cash Receipt (Applied)</th>
                        <th>Cash Payment</th>
                        <th>Total Received</th>
                        <th>Patient Credit</th>
                        <th>Total Invoice</th>
                        <th>Discount</th>
                        <th>Ending Balance (Dr+/Cr−)</th>
                        <th>Aging Days</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var r in Model.ArResults)
                {
                    <tr>
                        <td>@r.InvoiceId</td>
                        <td>@r.InvoiceDate.ToString("d")</td>
                        <td>@r.Patient</td>
                        <td>@r.Doctor</td>
                        <td>@r.Specialty</td>
                        <td>@r.CashReceipt.ToString("N2")</td>
                        <td>@r.CashPayment.ToString("N2")</td>
                        <td>@r.TotalReceived.ToString("N2")</td>
                        <td>@r.PatientCredit.ToString("N2")</td>
                        <td>@r.TotalInvoice.ToString("N2")</td>
                        <td>@r.Discount.ToString("N2")</td>
                        <td class="@(r.EndingBalance < 0 ? "text-success" : r.EndingBalance > 0 ? "text-danger" : "")">@AccountsReceivableModel.FormatEndingBalance(r.EndingBalance)</td>
                        <td>@r.AgingDays</td>
                        <td>@r.Status</td>
                    </tr>
                }
                </tbody>
                @if (Model.ArResults.Count > 0)
                {
                <tfoot>
                    <tr class="report-totals-row fw-bold">
                        <td colspan="5">Totals</td>
                        <td>@Model.ArTotalCashReceipt.ToString("N2")</td>
                        <td>@Model.ArTotalCashPayment.ToString("N2")</td>
                        <td></td>
                        <td>@Model.ArTotalPatientCredit.ToString("N2")</td>
                        <td>@Model.ArTotalInvoiceAmount.ToString("N2")</td>
                        <td>@Model.ArTotalDiscount.ToString("N2")</td>
                        <td>@AccountsReceivableModel.FormatEndingBalance(Model.ArTotalEndingBalance)</td>
                        <td colspan="2"></td>
                    </tr>
                </tfoot>
                }
            </table>
        </div>
        <div class="clinical-toolbar mt-3 no-print">
            <button type="button" class="btn-form btn-form-primary" id="patientHistoryPrintAllBtn">🖨️ Print All Patient Reports</button>
            <button type="button" class="btn-form" data-print-section="registration">🖨️ Patient Registration</button>
            <button type="button" class="btn-form" data-print-section="prescription">🖨️ Doctor's Prescription</button>
            <button type="button" class="btn-form" data-print-section="laboratoryrequest">🖨️ Laboratory Request</button>
            <button type="button" class="btn-form" data-print-section="laboratoryresult">🖨️ Laboratory Result</button>
            <button type="button" class="btn-form" data-print-section="radiologyrequest">🖨️ Radiology Request</button>
            <button type="button" class="btn-form" data-print-section="radiologyresult">🖨️ Radiology Result</button>
            <button type="button" class="btn-form" data-print-section="pharmacyrequest">🖨️ Pharmacy Request</button>
            <button type="button" class="btn-form" data-print-section="pharmacybill">🖨️ Pharmacy Bill</button>
            <button type="button" class="btn-form" data-print-section="invoice">🖨️ Invoice / Billing</button>
            <button type="button" class="btn-form" data-print-section="cashreceipt">🖨️ Cash Receipt</button>
            <button type="button" class="btn-form" data-print-section="cashpayment">🖨️ Cash Payment</button>
            <button type="button" class="btn-form" data-print-section="accountsreceivable">🖨️ Accounts Receivable</button>
            <button type="submit" asp-page-handler="Export" class="btn-form">Export to Excel</button>
            <button type="button" class="btn-form" onclick="clinicalPrintReport();">🖨️ Print History</button>
            <a asp-page="/Dashboard/Index" class="btn-form text-decoration-none text-dark">✕ Close</a>
        </div>
    </form>
</div>

<partial name="_PatientSelectModal" />
<partial name="_DoctorSelectModal" />

@section Scripts {
    <script src="~/js/patient-picker.js" asp-append-version="true"></script>
    <script src="~/js/doctor-picker.js" asp-append-version="true"></script>
    <script src="~/js/patient-history.js" asp-append-version="true"></script>
}
