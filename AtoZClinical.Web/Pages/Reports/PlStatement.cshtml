@page
@model AtoZClinical.Web.Pages.Reports.PlStatementModel
@{
    ViewData["Title"] = "PL Statement";
    ViewData["UseReportPickers"] = true;
    Layout = "_Layout";
    var snap = Model.Snapshot;
}

<div class="clinical-form-page clinical-report-page pl-qb-page">
    <h1 class="page-title">PL Statement</h1>
    <partial name="_ReportBranding" />
    <form method="post" id="clinicalReportForm">
        <button type="submit" asp-page-handler="Run" id="reportRunSubmit" class="d-none" aria-hidden="true"></button>
        <div class="report-filter-panel">
            <div class="row g-2 mb-0">
                <div class="col-md-2">
                    <label class="clinical-field-label">From Date</label>
                    <input asp-for="FromDate" class="clinical-field" type="date" />
                </div>
                <div class="col-md-2">
                    <label class="clinical-field-label">To Date</label>
                    <input asp-for="ToDate" class="clinical-field" type="date" />
                </div>
                <div class="col-md-3">
                    <label class="clinical-field-label">Doctor Name</label>
                    <input asp-for="DoctorName" id="reportDoctorNameInput" class="clinical-field doctor-picker-field" readonly placeholder="Click to select doctor..." />
                </div>
                <div class="col-md-3">
                    <label class="clinical-field-label">Patient Name</label>
                    <input asp-for="PatientName" id="reportPatientNameInput" class="clinical-field doctor-picker-field" readonly placeholder="Click to select patient..." />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <div class="form-check">
                        <input asp-for="NonZero" class="form-check-input" type="checkbox" />
                        <label class="form-check-label">Non Zero</label>
                    </div>
                </div>
            </div>
        </div>
        <p class="report-hint">
            Profit &amp; Loss from <strong>posted journal entries</strong> for @Model.FromDate.ToString("d") – @Model.ToDate.ToString("d").
            Income and expenses match General Ledger and Trial Balance for the same period.
        </p>

        @if (snap is not null)
        {
            <div class="pl-qb-report atz-card">
                <div class="pl-qb-header text-center">
                    <div class="pl-qb-company">@(ViewData["ReportClinicName"] as string ?? "Clinical")</div>
                    <div class="pl-qb-title">Profit and Loss</div>
                    <div class="pl-qb-period">@Model.FromDate.ToString("MMMM d, yyyy") – @Model.ToDate.ToString("MMMM d, yyyy")</div>
                </div>

                <div id="print-area" class="report-results-scroll">
                    <table class="line-grid report-grid pl-statement-grid pl-qb-grid">
                        <thead>
                            <tr>
                                <th>Account / Detail</th>
                                <th class="text-end">TOTAL</th>
                            </tr>
                        </thead>
                        <tbody>
                        <tr class="pl-section-row">
                            <td colspan="2"><span class="pl-section-label">▾ Income</span></td>
                        </tr>
                        @foreach (var r in snap.Income)
                        {
                            <tr class="pl-line-row">
                                <td class="pl-line-indent">@r.Account</td>
                                <td class="text-end">@r.Amount.ToString("N2")</td>
                            </tr>
                        }
                        <tr class="pl-subtotal-row">
                            <td>Total Income</td>
                            <td class="text-end">@snap.TotalIncome.ToString("N2")</td>
                        </tr>

                        <tr class="pl-section-row">
                            <td colspan="2"><span class="pl-section-label">▾ Cost of Goods Sold</span></td>
                        </tr>
                        @if (snap.CostOfGoodsSold.Count == 0)
                        {
                            <tr class="pl-line-row">
                                <td class="pl-line-indent">Cost of Goods Sold</td>
                                <td class="text-end">@snap.TotalCostOfGoodsSold.ToString("N2")</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var r in snap.CostOfGoodsSold)
                            {
                                <tr class="pl-line-row">
                                    <td class="pl-line-indent">@r.Account</td>
                                    <td class="text-end">@r.Amount.ToString("N2")</td>
                                </tr>
                            }
                        }
                        <tr class="pl-subtotal-row">
                            <td>Total Cost of Goods Sold</td>
                            <td class="text-end">@snap.TotalCostOfGoodsSold.ToString("N2")</td>
                        </tr>

                        <tr class="pl-highlight-row">
                            <td>Gross Profit</td>
                            <td class="text-end">@snap.GrossProfit.ToString("N2")</td>
                        </tr>

                        <tr class="pl-section-row">
                            <td colspan="2"><span class="pl-section-label">▾ Operating Expenses</span></td>
                        </tr>
                        @foreach (var r in snap.Expenses)
                        {
                            <tr class="pl-line-row">
                                <td class="pl-line-indent">@r.Account</td>
                                <td class="text-end">@r.Amount.ToString("N2")</td>
                            </tr>
                        }
                        <tr class="pl-subtotal-row">
                            <td>Total Expenses</td>
                            <td class="text-end">@snap.TotalExpenses.ToString("N2")</td>
                        </tr>

                        <tr class="pl-highlight-row pl-net-row">
                            <td>Net Income</td>
                            <td class="text-end">@snap.NetIncome.ToString("N2")</td>
                        </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <partial name="_ReportToolbar" />
    </form>
</div>

<partial name="_PatientSelectModal" />
<partial name="_DoctorSelectModal" />

@section Scripts {
    <script src="~/js/patient-picker.js" asp-append-version="true"></script>
    <script src="~/js/doctor-picker.js" asp-append-version="true"></script>
    <script src="~/js/report-filters.js" asp-append-version="true"></script>
    <script>document.addEventListener('DOMContentLoaded', () => initReportPickers());</script>
}
