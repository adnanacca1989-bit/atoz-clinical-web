@page
@model AtoZClinical.Web.Pages.Reports.PlStatementModel
@{
    ViewData["Title"] = "PL Statement";
    Layout = "_Layout";
}

<div class="clinical-form-page">
    <h1 class="page-title">PL Statement</h1>
    <form method="post">
        <div class="row g-3 mb-2">
            <div class="col-md-2">
                <label class="clinical-field-label">From Date</label>
                <input asp-for="FromDate" class="clinical-field" type="date" />
            </div>
            <div class="col-md-2">
                <label class="clinical-field-label">To Date</label>
                <input asp-for="ToDate" class="clinical-field" type="date" />
            </div>
            <div class="col-md-3">
                <label class="clinical-field-label">Doctor Name</label>
                <input asp-for="DoctorName" class="clinical-field" placeholder="Search doctor name..." />
            </div>
            <div class="col-md-3">
                <label class="clinical-field-label">Patient Name</label>
                <input asp-for="PatientName" class="clinical-field" placeholder="Search patient name..." />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <div class="form-check">
                    <input asp-for="NonZero" class="form-check-input" type="checkbox" />
                    <label class="form-check-label">Non Zero</label>
                </div>
            </div>
        </div>
        <div class="d-flex justify-content-end gap-4 mb-2 small">
            <span><strong>Net Revenue:</strong> @Model.NetRevenue.ToString("N2")</span>
            <span><strong>Expenses:</strong> @Model.Expenses.ToString("N2")</span>
            <span><strong>Net Profit:</strong> @Model.NetProfit.ToString("N2")</span>
        </div>
        <div class="clinical-record-grid" style="min-height: 400px;">
            <table>
                <thead><tr><th>Section</th><th>Account</th><th>Detail</th><th>Amount</th></tr></thead>
                <tbody>
                @foreach (var r in Model.Results)
                {
                    <tr>
                        <td>@r.Section</td>
                        <td>@r.Account</td>
                        <td>@r.Detail</td>
                        <td>@r.Amount.ToString("N2")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <partial name="_ReportToolbar" />
    </form>
</div>
