@page
@model AtoZClinical.Web.Pages.Pharmacy.RequestModel
@{
    ViewData["Title"] = "Pharmacy Request";
    ViewData["FormHint"] = "Click Patient Name to search. Choose items from the dropdown; use Show barcode & details to scan or edit codes.";
    Layout = "_Layout";
}

<div class="clinical-form-page clinical-standard-form">
    <h1 class="page-title">Pharmacy Request</h1>
    <div asp-validation-summary="All" class="validation-summary-errors"></div>
    <partial name="_ClinicalFormHint" />
    <form method="post">
        <div class="clinical-form-body">
            <div class="clinical-form-left clinical-form-scroll">
                <div class="row g-2 mb-2 clinical-form-header">
                    <div class="col-md-2">
                        <label class="clinical-field-label">Request ID</label>
                        <input asp-for="Input.RequestNo" class="clinical-field" readonly />
                    </div>
                    <div class="col-md-2">
                        <label class="clinical-field-label">Request Date</label>
                        <input asp-for="Input.RequestDate" class="clinical-field" type="date" />
                    </div>
                    <div class="col-md-2">
                        <label class="clinical-field-label">Prescription No</label>
                        <input asp-for="Input.PrescriptionNo" class="clinical-field" type="number" />
                    </div>
                    <div class="col-md-6">
                        <label class="clinical-field-label">Notes</label>
                        <input asp-for="Input.Notes" class="clinical-field" />
                    </div>
                    <div class="col-md-4">
                        <label class="clinical-field-label">Patient Name</label>
                        <input asp-for="Input.PatientName" id="pharmacyRequestPatientNameInput" class="clinical-field doctor-picker-field" readonly placeholder="Click to select patient..." />
                    </div>
                    <div class="col-md-2">
                        <label class="clinical-field-label">Patient Barcode</label>
                        <input asp-for="Input.PatientId" class="clinical-field" readonly />
                    </div>
                    <div class="col-md-2">
                        <label class="clinical-field-label">Age</label>
                        <input asp-for="Input.Age" class="clinical-field" type="number" readonly />
                    </div>
                    <div class="col-md-2">
                        <label class="clinical-field-label">Gender</label>
                        <input asp-for="Input.Gender" class="clinical-field" readonly />
                    </div>
                    <div class="col-md-4">
                        <label class="clinical-field-label">Phone</label>
                        <input asp-for="Input.Phone" class="clinical-field" readonly />
                    </div>
                    <div class="col-md-4">
                        <label class="clinical-field-label">City</label>
                        <input asp-for="Input.City" class="clinical-field" readonly />
                    </div>
                    <div class="col-md-4">
                        <label class="clinical-field-label">Doctor Name</label>
                        <input asp-for="Input.DoctorName" class="clinical-field" readonly />
                    </div>
                    <div class="col-md-4">
                        <label class="clinical-field-label">Specialty</label>
                        <input asp-for="Input.Specialty" class="clinical-field" readonly />
                    </div>
                </div>
                <div class="clinical-form-grid-area">
                <div class="section-caption-row">
                    <div class="section-caption">Request Lines</div>
                    <button type="button" class="btn-form btn-form-sm pharmacy-toggle-details">Show barcode &amp; details</button>
                </div>
                <div class="line-grid-scroll clinical-line-grid-scroll">
                <table class="line-grid pharmacy-line-grid pharmacy-line-grid-compact clinical-line-grid">
                    <thead>
                        <tr><th class="col-no">No</th><th class="col-item">Item</th><th class="pharmacy-col-detail">Barcode</th><th class="pharmacy-col-detail">Medicine Code</th><th class="col-medicine">Medicine Name</th><th class="pharmacy-col-detail">Dosage</th><th>UOM</th><th class="col-qty">QTY</th><th class="col-fee">Unit Price</th><th class="col-total">Total</th><th class="col-del">Del</th></tr>
                    </thead>
                    <tbody>
                    @for (var i = 0; i < Model.Lines.Count; i++)
                    {
                        var lineBarcode = Model.Lines[i].Barcode ?? "";
                        <tr class="pharmacy-line" data-line="@i">
                            <td><input asp-for="Lines[i].LineNo" readonly /></td>
                            <td>
                                <select class="pharmacy-item-select clinical-field">
                                    <option value="">-- Item --</option>
                                    @foreach (var item in Model.RegisteredItems)
                                    {
                                        <option value="@item.Barcode"
                                                selected="@(lineBarcode == item.Barcode)"
                                                data-barcode="@item.Barcode"
                                                data-code="@item.MedicineCode"
                                                data-name="@item.MedicineName"
                                                data-dosage="@item.Dosage"
                                                data-base-uom="@item.BaseUom"
                                                data-alt-uom="@item.AlternateUom"
                                                data-price="@item.DefaultUnitPrice"
                                                data-avg-cost="@item.MovingAverageCost"
                                                data-qty="@item.QuantityOnHand">@item.MedicineName</option>
                                    }
                                </select>
                            </td>
                            <td class="pharmacy-col-detail"><input asp-for="Lines[i].Barcode" class="pharmacy-barcode" /></td>
                            <td class="pharmacy-col-detail"><input asp-for="Lines[i].MedicineCode" class="pharmacy-code" /></td>
                            <td class="col-medicine"><input asp-for="Lines[i].MedicineName" class="pharmacy-name" readonly /></td>
                            <td class="pharmacy-col-detail"><input asp-for="Lines[i].Dosage" class="pharmacy-dosage" readonly /></td>
                            <td><input asp-for="Lines[i].Uom" class="pharmacy-uom clinical-field" placeholder="Pcs" /></td>
                            <td class="col-qty"><input asp-for="Lines[i].Qty" type="number" min="1" class="pharmacy-qty" /></td>
                            <td class="col-fee"><input asp-for="Lines[i].UnitPrice" type="number" step="0.01" class="pharmacy-price" /></td>
                            <td class="col-total"><input value="@(Model.Lines[i].Total.ToString("N2"))" readonly class="pharmacy-line-total" /></td>
                            <td class="col-del text-center"><button type="button" class="btn-form delete-line-btn" title="Delete line">🗑</button></td>
                        </tr>
                    }
                    </tbody>
                </table>
                </div>
                </div>
                <div class="clinical-form-totals-section clinical-grand-total-row">
                    <div class="clinical-grand-total-box">
                        <label class="clinical-field-label">Total Amount</label>
                        <input id="pharmacyRequestTotal" value="@Model.LineTotal.ToString("N2")" class="clinical-field clinical-grand-total-field" readonly />
                    </div>
                </div>
            </div>
            <div class="clinical-form-right">
                <div class="record-transaction-header">Record Transaction</div>
                <div class="record-transaction-status">@Model.StatusText</div>
                <div class="p-2">
                    <input id="searchBox" name="Search" value="@Model.Search" class="clinical-field mb-2" placeholder="Search..." />
                </div>
                <div class="clinical-record-grid">
                    <table>
                        <thead><tr><th>Request No</th><th>Date</th><th>Patient</th><th>Doctor</th><th>Total</th></tr></thead>
                        <tbody>
                        @foreach (var r in Model.Records)
                        {
                            <tr class="@(Model.RecordId == r.Id ? "selected" : "")" onclick="location.href='?RecordId=@r.Id'">
                                <td>@r.RequestNo</td>
                                <td>@r.RequestDate.ToString("d")</td>
                                <td>@r.PatientName</td>
                                <td>@r.DoctorName</td>
                                <td>@r.TotalAmount.ToString("N2")</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <input type="hidden" asp-for="RecordId" />
        <partial name="_FormToolbar" />
        <div class="clinical-form-footer">
            <span>Created By: @Model.UserName</span>
            <span>Last Updated By: @Model.UserName</span>
        </div>
    </form>
</div>

<partial name="_PatientSelectModal" />

@section Scripts {
    <script src="~/js/patient-picker.js" asp-append-version="true"></script>
    <script src="~/js/clinical-line-grid.js" asp-append-version="true"></script>
    <script src="~/js/pharmacy-grid-enhancements.js" asp-append-version="true"></script>
    <script src="~/js/pharmacy-line-calculations.js" asp-append-version="true"></script>
    <script src="~/js/pharmacy-request.js" asp-append-version="true"></script>
    <script src="~/js/pharmacy-barcode.js" asp-append-version="true"></script>
}
