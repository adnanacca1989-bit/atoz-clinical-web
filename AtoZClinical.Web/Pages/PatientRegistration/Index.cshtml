@page
@model AtoZClinical.Web.Pages.PatientRegistration.IndexModel
@{
    ViewData["Title"] = "Patient Registration";
    Layout = "_Layout";
}

<div class="clinical-form-page">
    <h1 class="page-title">Patient Registration</h1>
    <div asp-validation-summary="All" class="validation-summary-errors mx-3"></div>
    <form method="post">
        <div class="clinical-form-body">
            <div class="clinical-form-left">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="clinical-field-label">Patient No</label>
                        <input asp-for="Input.PatientNo" class="clinical-field" readonly />
                    </div>
                    <div class="col-md-5">
                        <label class="clinical-field-label field-required">Patient Name</label>
                        <input asp-for="Input.PatientName" class="clinical-field" required />
                        <span asp-validation-for="Input.PatientName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-2">
                        <label class="clinical-field-label field-required">Gender</label>
                        <select asp-for="Input.Gender" class="clinical-field" required>
                            <option>Male</option>
                            <option>Female</option>
                        </select>
                        <span asp-validation-for="Input.Gender" class="text-danger small"></span>
                    </div>
                    <div class="col-md-2">
                        <label class="clinical-field-label">Age</label>
                        <input id="patientAge" value="@(Model.Input.DisplayAge?.ToString() ?? "")" class="clinical-field" readonly />
                    </div>
                    <div class="col-md-3">
                        <label class="clinical-field-label field-required">Date of Birth</label>
                        <input asp-for="Input.DateOfBirth" id="patientDateOfBirth" class="clinical-field" type="date" required />
                        <span asp-validation-for="Input.DateOfBirth" class="text-danger small"></span>
                    </div>
                    <div class="col-md-3">
                        <label class="clinical-field-label field-required">Phone</label>
                        <input asp-for="Input.Phone" class="clinical-field" required />
                        <span asp-validation-for="Input.Phone" class="text-danger small"></span>
                    </div>
                    <div class="col-md-3">
                        <label class="clinical-field-label field-required">City</label>
                        <select asp-for="Input.City" class="clinical-field" asp-items="@(new SelectList(AtoZClinical.Infrastructure.Services.ClinicLookup.Cities))" required></select>
                        <span asp-validation-for="Input.City" class="text-danger small"></span>
                    </div>
                    <div class="col-md-3">
                        <label class="clinical-field-label">Blood Group</label>
                        <select asp-for="Input.BloodGroup" class="clinical-field" asp-items="@(new SelectList(AtoZClinical.Infrastructure.Services.ClinicLookup.BloodGroups))">
                            <option value="">--</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="clinical-field-label field-required">Doctor Name</label>
                        <input asp-for="Input.DoctorName" id="doctorNameInput" class="clinical-field doctor-picker-field" readonly placeholder="Click to select doctor..." required />
                        <span asp-validation-for="Input.DoctorName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label class="clinical-field-label field-required">Specialty</label>
                        <select asp-for="Input.Specialty" id="specialtySelect" class="clinical-field" asp-items="@(new SelectList(AtoZClinical.Infrastructure.Services.ClinicLookup.Specialties))" required>
                            <option value="">-- Select --</option>
                        </select>
                        <span asp-validation-for="Input.Specialty" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label class="clinical-field-label">National ID</label>
                        <input asp-for="Input.NationalId" id="nationalIdInput" class="clinical-field" />
                    </div>
                    <div class="col-md-6">
                        <label class="clinical-field-label">Address</label>
                        <input asp-for="Input.Address" class="clinical-field" />
                    </div>
                    <div class="col-md-6">
                        <label class="clinical-field-label">Emergency Contact</label>
                        <input asp-for="Input.EmergencyContact" class="clinical-field" />
                    </div>
                    <div class="col-md-4">
                        <label class="clinical-field-label">Health Insurance</label>
                        <input asp-for="Input.HealthInsuranceName" class="clinical-field" placeholder="Insurance company / plan name" />
                    </div>
                    <div class="col-md-4">
                        <label class="clinical-field-label">Health Insurance No</label>
                        <input asp-for="Input.HealthInsuranceNumber" class="clinical-field" placeholder="Policy / member number" />
                    </div>
                    <div class="col-md-3">
                        <label class="clinical-field-label">Appointment ID</label>
                        <input asp-for="Input.AppointmentId" class="clinical-field" readonly />
                    </div>
                    <div class="col-md-3">
                        <label class="clinical-field-label">Visit Number</label>
                        <input asp-for="Input.VisitNumber" id="visitNumberInput" class="clinical-field" />
                    </div>
                    <div class="col-md-3">
                        <label class="clinical-field-label field-required">Appointment Date</label>
                        <input asp-for="Input.AppointmentDate" class="clinical-field" type="date" required />
                        <span asp-validation-for="Input.AppointmentDate" class="text-danger small"></span>
                    </div>
                    <div class="col-md-3">
                        <label class="clinical-field-label field-required">Appointment Time</label>
                        <input asp-for="Input.AppointmentTime" class="clinical-field" type="time" required />
                        <span asp-validation-for="Input.AppointmentTime" class="text-danger small"></span>
                    </div>
                    <div class="col-md-3">
                        <label class="clinical-field-label">Status</label>
                        <select asp-for="Input.Status" class="clinical-field">
                            <option>Pending</option>
                            <option>Confirmed</option>
                            <option>Under Process</option>
                            <option>Completed</option>
                            <option>Cancelled</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="clinical-form-right">
                <div class="record-transaction-header">Record Transaction</div>
                <div class="record-transaction-status">@Model.StatusText</div>
                <div class="p-2">
                    <input id="searchBox" name="Search" value="@Model.Search" class="clinical-field mb-2" placeholder="Search..." />
                </div>
                <div class="clinical-record-grid">
                    <table>
                        <thead><tr><th>Patient ID</th><th>Patient Name</th><th>Age</th><th>City</th><th>Mobile</th></tr></thead>
                        <tbody>
                        @foreach (var r in Model.Records)
                        {
                            <tr class="@(Model.RecordId == r.Id ? "selected" : "")" onclick="location.href='?RecordId=@r.Id'">
                                <td>@r.PatientNo</td>
                                <td>@r.FullName</td>
                                <td>@(r.AgeYears?.ToString() ?? "")</td>
                                <td>@r.City</td>
                                <td>@r.Phone</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
                <div class="record-footer patient-stats">
                    <div class="patient-stat-box total"><div class="num">@Model.TotalPatients</div><div>Total Patients</div></div>
                    <div class="patient-stat-box today"><div class="num">@Model.TodayPatients</div><div>Today</div></div>
                    <div class="patient-stat-box active"><div class="num">@Model.ActivePatients</div><div>Active</div></div>
                    <div class="patient-stat-box inactive"><div class="num">@Model.InactivePatients</div><div>Inactive</div></div>
                </div>
            </div>
        </div>
        <input type="hidden" asp-for="RecordId" />
        <partial name="_FormToolbar" />
        <div class="clinical-form-footer">
            <span>Created By: @(Model.Input.CreatedBy ?? Model.UserName)</span>
            <span>Last Updated By: @(Model.Input.UpdatedBy ?? Model.UserName)</span>
        </div>
    </form>
</div>

<partial name="_DoctorSelectModal" />
<partial name="_PatientCardModal" />
<partial name="_PatientHistoryModal" />

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.6/dist/JsBarcode.all.min.js"></script>
    <script src="~/js/patient-registration.js" asp-append-version="true"></script>
}
