@page
@model AtoZClinical.Web.Pages.Laboratory.RegistrationModel
@{
    ViewData["Title"] = "Laboratory Registration";
    Layout = "_Layout";
}

<div class="clinical-form-page">
    <h1 class="page-title">Laboratory Registration</h1>
    <div asp-validation-summary="All" class="validation-summary-errors mx-3"></div>
    <form method="post">
        <div class="clinical-form-body">
            <div class="clinical-form-left">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="clinical-field-label">Test No</label>
                        <input asp-for="Input.TestNo" class="clinical-field" readonly />
                    </div>
                    <div class="col-md-3">
                        <label class="clinical-field-label">Test Code</label>
                        <input asp-for="Input.TestCode" class="clinical-field" />
                    </div>
                    <div class="col-md-6">
                        <label class="clinical-field-label">Test Name</label>
                        <input asp-for="Input.TestName" class="clinical-field" />
                    </div>
                    <div class="col-md-4">
                        <label class="clinical-field-label">Category</label>
                        <select asp-for="Input.Category" class="clinical-field" asp-items="@(new SelectList(AtoZClinical.Infrastructure.Services.ClinicLookup.LabCategories))"></select>
                    </div>
                    <div class="col-md-4">
                        <label class="clinical-field-label">Fee</label>
                        <input asp-for="Input.Fee" class="clinical-field" type="number" step="0.01" />
                    </div>
                    <div class="col-md-12">
                        <label class="clinical-field-label">Note</label>
                        <input asp-for="Input.Note" class="clinical-field" />
                    </div>
                </div>
            </div>
            <div class="clinical-form-right">
                <div class="record-transaction-header">Record Transaction</div>
                <div class="record-transaction-status">@Model.StatusText</div>
                <div class="p-2">
                    <input id="searchBox" name="Search" value="@Model.Search" class="clinical-field mb-2" placeholder="Search..." />
                </div>
                <div class="clinical-record-grid">
                    <table>
                        <thead><tr><th>ID</th><th>Test Code</th><th>Test Name</th><th>Category</th><th>Fee</th><th>Note</th></tr></thead>
                        <tbody>
                        @foreach (var r in Model.Records)
                        {
                            <tr class="@(Model.RecordId == r.Id ? "selected" : "")" onclick="location.href='?RecordId=@r.Id'">
                                <td>@r.TestNo</td>
                                <td>@r.TestCode</td>
                                <td>@r.TestName</td>
                                <td>@r.Category</td>
                                <td>@r.Fee.ToString("N2")</td>
                                <td>@r.Note</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <input type="hidden" asp-for="RecordId" />
        <partial name="_FormToolbar" />
        <div class="clinical-form-footer">
            <span>Created By: @Model.UserName</span>
            <span>Last Updated By: @Model.UserName</span>
        </div>
    </form>
</div>
