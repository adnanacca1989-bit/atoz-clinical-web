<div class="modal fade" id="patientSelectModal" tabindex="-1" aria-labelledby="patientSelectModalLabel" aria-hidden="true">

    <div class="modal-dialog modal-xl modal-dialog-scrollable">

        <div class="modal-content doctor-select-modal">

            <div class="modal-header py-2">

                <h5 class="modal-title" id="patientSelectModalLabel">Select Patient</h5>

                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>

            </div>

            <div class="modal-body p-3">

                <h6 class="fw-bold mb-2">Patient Search</h6>

                <input type="text" id="patientSearchInput" class="clinical-field mb-3"

                       placeholder="Search patient by ID, name, phone, city, doctor, specialty..." />

                <div class="clinical-record-grid doctor-select-grid">

                    <table>

                        <thead>

                            <tr>

                                <th>Patient ID</th>

                                <th>Patient Name</th>

                                <th>Gender</th>

                                <th>Age</th>

                                <th>Phone</th>

                                <th>City</th>

                                <th>Doctor Name</th>

                                <th>Specialty</th>

                                <th>Appt. Date</th>

                                <th>Appt. Time</th>

                                <th>Status</th>

                            </tr>

                        </thead>

                        <tbody id="patientSelectTableBody"></tbody>

                    </table>

                </div>

            </div>

            <div class="modal-footer doctor-select-footer">

                <button type="button" class="btn-form btn-form-primary" id="patientSelectAddBtn">💾 Add</button>

                <button type="button" class="btn-form" id="patientSelectRefreshBtn" title="Refresh">🔄</button>

                <button type="button" class="btn-form" id="patientSelectClearBtn">🧹 Clear</button>

                <button type="button" class="btn-form" data-bs-dismiss="modal">✕ Close</button>

            </div>

        </div>

    </div>

</div>


