@{
    var showHistory = ViewData["ShowHistory"] as bool? ?? false;
    var showPatientCard = ViewData["ShowPatientCard"] as bool? ?? false;
    var openPatientSelect = ViewData["OpenPatientSelect"] as bool? ?? false;
    var showAddLines = ViewData["ShowAddLines"] as bool? ?? false;
    var isEditMode = ViewData["IsEditMode"] as bool? ?? false;
    var formMode = ViewData["FormMode"] as string ?? "New";
    var formModeLabel = ViewData["FormModeLabel"] as string ?? "New Record Mode";
}
<partial name="_FormMetaBar" />
@if (TempData["FormSuccessMessage"] is string successMsg)
{
    <div class="clinical-form-success-alert no-print" role="status">@successMsg</div>
}
<div class="clinical-form-mode-banner no-print clinical-form-mode-@formMode.ToLowerInvariant()">
    <span class="clinical-form-mode-label">@formModeLabel</span>
</div>
<input type="hidden" name="SaveMode" id="saveModeInput" value="@(isEditMode ? "Edit" : "New")" />
<div class="clinical-toolbar">
    <button type="submit" asp-page-handler="New" class="btn-form" formnovalidate>+ New</button>
    @if (isEditMode)
    {
        <button type="submit" asp-page-handler="Save" class="btn-form btn-form-primary">💾 Update</button>
    }
    else
    {
        <button type="submit" asp-page-handler="Add" class="btn-form btn-form-primary">💾 Save</button>
    }
    <button type="submit" asp-page-handler="Delete" class="btn-form" formnovalidate onclick="return confirm('Delete this record?');">🗑️ Delete</button>
    @if (openPatientSelect)
    {
        <button type="button" class="btn-form" id="openPatientSelectBtn">🔍 Search</button>
    }
    else
    {
        <button type="button" class="btn-form" onclick="document.getElementById('searchBox')?.focus();">🔍 Search</button>
    }
    <button type="button" class="btn-form" onclick="window.location.reload();" title="Reload page">🔄 Refresh</button>
    <button type="submit" asp-page-handler="Clear" class="btn-form" formnovalidate>🧹 Clear</button>
    <button type="button" class="btn-form" onclick="clinicalPrintForm();">🖨️ Print</button>
    <a asp-page="/Dashboard/Index" class="btn-form text-decoration-none text-dark">✕ Close</a>
    <button type="submit" asp-page-handler="Back" class="btn-form" formnovalidate>← Back</button>
    <button type="submit" asp-page-handler="Next" class="btn-form" formnovalidate>Next →</button>
    @if (showAddLines)
    {
        <button type="button" class="btn-form" id="addClinicalLinesBtn">+ Add Lines</button>
    }
    @if (showHistory) { <button type="button" class="btn-form" id="patientHistoryBtn">📋 History</button> }
    @if (showPatientCard) { <button type="button" class="btn-form" id="patientCardBtn">Patient Card</button> }
</div>
