@model AtoZClinical.Web.Services.PatientPrintBundle

@if (Model.Sections.Count == 0)
{
    <section class="a4-page">
        <h2 class="print-doc-title">Patient Reports</h2>
        <p>No records found for patient <strong>@Model.PatientName</strong> @(string.IsNullOrWhiteSpace(Model.PatientId) ? "" : $"({Model.PatientId})").</p>
    </section>
}
else
{
    @foreach (var doc in Model.Sections)
    {
        <section class="a4-page">
            <h2 class="print-doc-title">@doc.Title</h2>
            <div class="print-doc-meta">
                @foreach (var field in doc.HeaderFields)
                {
                    <span><strong>@field.Key:</strong> @field.Value</span>
                }
            </div>
            @if (doc.Columns is { Length: > 0 })
            {
                @if (doc.Rows.Count > 0)
                {
                <table class="print-doc-table">
                    <thead>
                        <tr>@foreach (var col in doc.Columns) { <th>@col</th> }</tr>
                    </thead>
                    <tbody>
                        @foreach (var row in doc.Rows)
                        {
                            var isTotals = doc.Title == "Accounts Receivable Statement" &&
                                           row.Length > 2 && row[2] == "Totals";
                            <tr class="@(isTotals ? "print-doc-totals-row fw-bold" : "")">@foreach (var cell in row) { <td>@cell</td> }</tr>
                        }
                    </tbody>
                </table>
                }
                else
                {
                    <p class="print-doc-empty">No line items on file for this report.</p>
                }
            }
            @if (doc.FooterFields is { Count: > 0 })
            {
                @if (doc.Title == "Invoice / Billing")
                {
                    <div class="print-bundle-invoice-footer">
                        <table class="print-bundle-totals">
                            <tbody>
                            @foreach (var field in doc.FooterFields)
                            {
                                var rowClass = field.Key switch
                                {
                                    "Total" => "bundle-total-row",
                                    "Balance Due" => "bundle-balance-row",
                                    _ => ""
                                };
                                <tr class="@rowClass"><td>@field.Key</td><td>@field.Value</td></tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="print-doc-footer">
                        @foreach (var field in doc.FooterFields)
                        {
                            <div><strong>@field.Key:</strong> @field.Value</div>
                        }
                    </div>
                }
            }
        </section>
    }
}
