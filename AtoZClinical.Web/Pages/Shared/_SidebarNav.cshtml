@using AtoZClinical.Infrastructure
@using AtoZClinical.Infrastructure.Services
@{
    var visible = Context.Items[FormPermissionService.VisibleFormsItemKey] as HashSet<string>;
}

@foreach (var section in ClinicalNavCatalog.Sections)
{
    if (!ClinicalNavCatalog.IsSectionVisible(section, visible))
    {
        continue;
    }

    <div class="text-white-50 small mt-3 mb-1">@(section.Label)</div>

    foreach (var group in section.Groups)
    {
        var groupLinks = group.Links.Where(l => ClinicalNavCatalog.IsLinkVisible(l, visible)).ToList();
        if (groupLinks.Count == 0)
        {
            continue;
        }

        if (!string.IsNullOrWhiteSpace(group.SubLabel))
        {
            <div class="text-white-50 small mt-2 mb-1 ps-2" style="font-size: 0.7rem; letter-spacing: 0.04em;">@group.SubLabel</div>
        }

        foreach (var link in groupLinks)
        {
            <a class="sidebar-link" asp-page="@link.Page">@link.Label</a>
        }
    }
}
