@using AtoZClinical.Infrastructure
@using AtoZClinical.Infrastructure.Services
@functions {
    bool NavCan(string key)
    {
        var visible = Context.Items[FormPermissionService.VisibleFormsItemKey] as HashSet<string>;
        return visible is null || visible.Contains(key);
    }
}

