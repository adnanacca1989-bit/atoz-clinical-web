<div class="modal fade" id="doctorSelectModal" tabindex="-1" aria-labelledby="doctorSelectModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content doctor-select-modal">
            <div class="modal-header py-2">
                <h5 class="modal-title" id="doctorSelectModalLabel">Select Doctor</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-3">
                <h6 class="fw-bold mb-2">Doctor Search</h6>
                <input type="text" id="doctorSearchInput" class="clinical-field mb-3"
                       placeholder="Search doctor by ID, name, specialty, phone, email..." />
                <div class="clinical-record-grid doctor-select-grid">
                    <table>
                        <thead>
                            <tr>
                                <th>Doctor ID</th>
                                <th>Doctor Name</th>
                                <th>Specialty</th>
                                <th>Phone</th>
                                <th>Email</th>
                                <th>Consultation</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody id="doctorSelectTableBody"></tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer doctor-select-footer">
                <button type="button" class="btn-form btn-form-primary" id="doctorSelectAddBtn">💾 Add</button>
                <button type="button" class="btn-form" id="doctorSelectRefreshBtn" title="Refresh">🔄</button>
                <button type="button" class="btn-form" id="doctorSelectClearBtn">🧹 Clear</button>
                <button type="button" class="btn-form" data-bs-dismiss="modal">✕ Close</button>
            </div>
        </div>
    </div>
</div>
