<div class="modal fade" id="columnFilterModal" tabindex="-1" aria-labelledby="columnFilterTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="columnFilterTitle">Column Filter</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-2 fw-semibold">Select the columns to show in this report.</p>
                <div id="columnFilterList" class="column-filter-list border rounded p-3"></div>
            </div>
            <div class="modal-footer d-flex justify-content-between">
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-outline-secondary btn-sm" id="columnFilterSelectAllBtn">Select All</button>
                    <button type="button" class="btn btn-outline-secondary btn-sm" id="columnFilterClearAllBtn">Clear All</button>
                </div>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-outline-secondary" id="columnFilterCancelBtn">Cancel</button>
                    <button type="button" class="btn btn-primary" id="columnFilterApplyBtn">Apply</button>
                </div>
            </div>
        </div>
    </div>
</div>
