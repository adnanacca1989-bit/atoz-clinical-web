<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - A to Z Clinical</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/clinical.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/clinical-forms.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/clinical-print.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <nav class="navbar navbar-dark atz-navbar mb-0">
            <div class="container-fluid">
                <a class="navbar-brand atz-brand" asp-page="/Dashboard/Index">A to Z Clinical</a>
                <div class="d-flex align-items-center gap-2 text-white small">
                    <span class="text-white-50">@AppBuildInfo.Version</span>
                    <span class="navbar-user-name">@User.Identity.Name</span>
                    <partial name="_SettingsGear" />
                    <a class="btn btn-sm btn-warning position-relative appt-reminder-nav-btn"
                       asp-page="/Reports/AppointmentReminders"
                       title="Appointment Reminders">
                        🗓️ Reminders
                        <span id="apptReminderBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none">0</span>
                    </a>
                    <div class="dropdown">
                        <button class="btn btn-sm btn-outline-light position-relative dropdown-toggle clinical-notify-bell"
                                type="button" id="clinicalNotifyBell" data-bs-toggle="dropdown" aria-expanded="false"
                                title="Notifications">
                            🔔
                            <span id="clinicalNotifyBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none">0</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end clinical-notify-menu" id="clinicalNotifyMenu" aria-labelledby="clinicalNotifyBell">
                            <li class="dropdown-header">Notifications</li>
                            <div id="clinicalNotifyList"></div>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item small" asp-page="/Reports/AppointmentReminders">Open Appointment Reminders</a></li>
                        </ul>
                    </div>
                    <form method="post" asp-page="/Account/Logout" class="m-0">
                        <button type="submit" class="btn btn-sm btn-outline-light">Logout</button>
                    </form>
                </div>
            </div>
        </nav>
        <div class="container-fluid">
            <div class="row">
                <aside class="col-md-2 col-lg-2 p-0 atz-navbar min-vh-100 atz-sidebar">
                    <div class="p-3 atz-sidebar-inner">
                        @if (User.IsInRole("Vendor"))
                        {
                            <div class="text-white-50 small mb-2">VENDOR</div>
                            <a class="sidebar-link" asp-page="/Vendor/Index">Clinics / Clients</a>
                            <a class="sidebar-link" asp-page="/Vendor/Clients">Existing Clients</a>
                            <a class="sidebar-link" asp-page="/Vendor/Create">New Client</a>
                        }
                        else
                        {
                            <partial name="_SidebarNav" />
                        }
                    </div>
                </aside>
                <main class="col-md-10 col-lg-10 px-3 py-2">
                    @RenderBody()
                </main>
            </div>
        </div>
    }
    else
    {
        <main>
            @RenderBody()
        </main>
    }

    @if (User.Identity?.IsAuthenticated == true && !User.IsInRole("Vendor"))
    {
        <partial name="_ColumnFilterModal" />
    }
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/clinical-print.js" asp-append-version="true"></script>
    @if (User.Identity?.IsAuthenticated == true && !User.IsInRole("Vendor"))
    {
        <script src="~/js/patient-picker.js" asp-append-version="true"></script>
        <script src="~/js/clinical-column-filter.js" asp-append-version="true"></script>
        <script src="~/js/appointment-reminders.js" asp-append-version="true"></script>
        <script src="~/js/clinical-notifications.js" asp-append-version="true"></script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
