<div class="dropdown">
    <button class="btn btn-sm btn-outline-light settings-gear-btn d-flex align-items-center justify-content-center"
            type="button" data-bs-toggle="dropdown" aria-expanded="false" title="Settings">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
            <path d="M8 4.754a3.246 3.246 0 1 0 0 6.492 3.246 3.246 0 0 0 0-6.492zM5.754 8a2.246 2.246 0 1 1 4.492 0 2.246 2.246 0 0 1-4.492 0z"/>
            <path d="M9.796 1.343c-.527-1.79-3.065-1.79-3.592 0l-.094.319a.873.873 0 0 1-1.255.52l-.292-.16c-1.64-.892-3.433.902-2.54 2.541l.159.292a.873.873 0 0 1-.52 1.255l-.319.094c-1.79.527-1.79 3.065 0 3.592l.319.094a.873.873 0 0 1 .52 1.255l-.16.292c-.892 1.64.901 3.434 2.541 2.54l.292-.159a.873.873 0 0 1 1.255.52l.094.319c.527 1.79 3.065 1.79 3.592 0l.094-.319a.873.873 0 0 1 1.255-.52l.292.16c1.64.893 3.434-.902 2.54-2.541l-.159-.292a.873.873 0 0 1 .52-1.255l.319-.094c1.79-.527 1.79-3.065 0-3.592l-.319-.094a.873.873 0 0 1-.52-1.255l.16-.292c.893-1.64-.902-3.433-2.541-2.54l-.292.159a.873.873 0 0 1-1.255-.52l-.094-.319z"/>
        </svg>
    </button>
    <ul class="dropdown-menu dropdown-menu-end settings-dropdown shadow">
        <li class="dropdown-header">System Settings</li>
        @if (!User.IsInRole("Vendor"))
        {
            <li><a class="dropdown-item" asp-page="/Settings/ClinicProfile">Clinic Profile &amp; Branding</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item" asp-page="/Settings/Uom">Define UOM</a></li>
            <li><a class="dropdown-item" asp-page="/Settings/Currency">Define Currency</a></li>
            <li><a class="dropdown-item" asp-page="/Settings/Vendor">Define Vendor</a></li>
            <li><a class="dropdown-item" asp-page="/Settings/Owner">Define Owner</a></li>
            <li><a class="dropdown-item" asp-page="/Settings/Language">Define Language</a></li>
            <li><a class="dropdown-item" asp-page="/Settings/Maintenance">Maintenance</a></li>
            <li><a class="dropdown-item" asp-page="/Settings/FormStyle">Style Forms</a></li>
            <li><a class="dropdown-item" asp-page="/Settings/Users">Define User</a></li>
            <li><hr class="dropdown-divider"></li>
        }
        <li><a class="dropdown-item" asp-page="/Settings/ChangePassword">Change Password</a></li>
        <li><hr class="dropdown-divider"></li>
        <li><a class="dropdown-item text-muted small" asp-page="/Settings/Index">All Settings</a></li>
    </ul>
</div>
