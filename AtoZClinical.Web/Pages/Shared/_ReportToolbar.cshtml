@{
    var useReportPickers = ViewData["UseReportPickers"] as bool? ?? false;
}

<div class="clinical-toolbar report-toolbar">
  @if (useReportPickers)
  {
    <button type="button" id="reportOpenPatientBtn" class="btn-form btn-form-primary" title="Search patients">Patient Search</button>
  }
  <button type="submit" asp-page-handler="Run" class="btn-form btn-form-primary" title="Run report with current filters">Run Report</button>
  <button type="button" class="btn-form" id="reportColumnFilterBtn" title="Show or hide columns">Columns</button>
  <button type="button" class="btn-form" onclick="window.location.reload();" title="Reload page">Refresh</button>
  <button type="submit" asp-page-handler="Export" class="btn-form" title="Download Excel">Export Excel</button>
  <button type="button" class="btn-form" onclick="clinicalPrintReport();" title="Print report">Print</button>
  <button type="submit" asp-page-handler="Clear" class="btn-form" title="Clear filters">Clear</button>
  <a asp-page="/Dashboard/Index" class="btn-form text-decoration-none text-dark" title="Close report">Close</a>
</div>
