@{

    var useReportPickers = ViewData["UseReportPickers"] as bool? ?? false;

}

<div class="clinical-toolbar">

    @if (useReportPickers)

    {

        <button type="button" id="reportOpenPatientBtn" class="btn-form btn-form-primary">🔍 Search</button>

        <button type="submit" asp-page-handler="Run" class="btn-form">Run</button>

    }

    else

    {

        <button type="submit" asp-page-handler="Run" class="btn-form btn-form-primary">🔍 Search</button>

        <button type="submit" asp-page-handler="Run" class="btn-form">Run</button>

    }

    <button type="button" class="btn-form" onclick="window.location.reload();" title="Reload page">🔄 Refresh</button>

    <button type="button" class="btn-form" onclick="document.getElementById('reportPatientNameInput')?.click();">🔍</button>

    <button type="submit" asp-page-handler="Export" class="btn-form">Export to Excel</button>

    <button type="button" class="btn-form" onclick="clinicalPrintReport();">🖨️ Print</button>

    <button type="submit" asp-page-handler="Clear" class="btn-form">🧹 Clear</button>

    <a asp-page="/Dashboard/Index" class="btn-form text-decoration-none text-dark">✕ Close</a>

</div>

