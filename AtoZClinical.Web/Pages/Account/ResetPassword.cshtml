@page
@model AtoZClinical.Web.Pages.Account.ResetPasswordModel
@{
    ViewData["Title"] = "Reset Password";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Password - A to Z Clinical</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/clinical.css" asp-append-version="true" />
</head>
<body>
    <div class="login-panel atz-card p-4">
        <div class="text-center mb-4">
            <h3 class="fw-bold" style="color:#0b4f8a">Reset Password</h3>
        </div>
        @if (Model.Succeeded)
        {
            <div class="alert alert-success">Your password has been reset.</div>
            <a class="btn btn-atz-primary w-100" asp-page="/Account/Login">Login</a>
        }
        else if (!Model.TokenValid)
        {
            <div class="alert alert-warning">This reset link is invalid or has expired.</div>
            <a class="btn btn-atz-primary w-100" asp-page="/Account/ForgotPassword">Request a new link</a>
        }
        else
        {
            <form method="post">
                <input type="hidden" asp-for="Input.Token" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label"></label>
                    <input asp-for="Input.Password" class="form-control" autocomplete="new-password" />
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Input.ConfirmPassword" class="form-label"></label>
                    <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" />
                </div>
                <button type="submit" class="btn btn-atz-primary w-100">Update Password</button>
            </form>
        }
    </div>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
