@page
@using AtoZClinical.Infrastructure.Services
@model AtoZClinical.Web.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password - A to Z Clinical</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/clinical.css" asp-append-version="true" />
</head>
<body>
    <div class="login-panel atz-card p-4">
        <div class="text-center mb-4">
            <h3 class="fw-bold" style="color:#0b4f8a">Forgot Password</h3>
            <p class="text-muted mb-0">Enter the email address for your account</p>
        </div>
        @if (Model.Submitted)
        {
            @if (!string.IsNullOrWhiteSpace(Model.UserFacingMessage))
            {
                <div class="alert alert-warning">@Model.UserFacingMessage</div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.EmailConfigurationWarningHtml))
            {
                <div class="alert alert-warning">
                    @Html.Raw(Model.EmailConfigurationWarningHtml)
                </div>
            }
            <div class="alert alert-info">
                If the email exists, a reset link has been sent. Check your inbox and spam folder.
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.UserFacingMessage))
            {
                <p class="text-muted small mb-0">No email was sent until SMTP is configured on the server.</p>
            }
            <a class="btn btn-atz-primary w-100" asp-page="/Account/Login">Back to Login</a>
        }
        else if (Model.EmailDeliveryFailed)
        {
            <div class="alert alert-danger">
                @Model.UserErrorMessage
            </div>
            <button type="button" class="btn btn-atz-primary w-100 mb-2" onclick="location.reload()">Try Again</button>
            <a class="btn btn-outline-secondary w-100" asp-page="/Account/Login">Back to Login</a>
        }
        else
        {
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label"></label>
                    <input asp-for="Input.Email" class="form-control" autocomplete="email" type="email" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>
                <button type="submit" class="btn btn-atz-primary w-100 mb-2">Submit</button>
                <a class="btn btn-outline-secondary w-100" asp-page="/Account/Login">Cancel</a>
            </form>
        }
    </div>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
