@page
@model AtoZClinical.Web.Pages.CashPayments.IndexModel
@{
    ViewData["Title"] = "Cash Payment";
    Layout = "_Layout";
}

<div class="clinical-form-page clinical-form-expanded clinical-form-erp-layout">
    <h1 class="page-title">Cash Payment</h1>
    <form method="post">
        <div asp-validation-summary="All" class="validation-summary-errors mx-3"></div>
        <div class="clinical-form-body">
            <div class="clinical-form-left">
                <div class="clinical-form-fields-scroll">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="clinical-field-label">Cash Payment ID</label>
                        <input asp-for="Input.PaymentNo" class="clinical-field" readonly />
                    </div>
                    <div class="col-md-3">
                        <label class="clinical-field-label field-required">Date</label>
                        <input asp-for="Input.PaymentDate" class="clinical-field" type="date" required />
                        <span asp-validation-for="Input.PaymentDate" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="clinical-field-label">Vendor</label>
                        <select asp-for="Input.VendorId" id="cashPaymentVendorSelect" class="clinical-field">
                            <option value="">-- Patient Payment (no vendor) --</option>
                            @foreach (var v in Model.RegisteredVendors)
                            {
                                <option value="@v.Id" selected="@(Model.Input.VendorId == v.Id ? "selected" : null)">@v.Name</option>
                            }
                        </select>
                        <span class="small text-muted">Linked to Settings → Define Vendor. Vendor payments post to Accounts Payable when Credit is selected.</span>
                    </div>
                    <div class="col-md-6 patient-payment-fields @(Model.IsVendorPayment ? "d-none" : "")">
                        <label class="clinical-field-label">Patient Name</label>
                        <input asp-for="Input.PayeeName" id="cashPaymentPatientNameInput" class="clinical-field doctor-picker-field" readonly placeholder="Click to select patient..." />
                    </div>
                    <div class="col-md-3 patient-payment-fields @(Model.IsVendorPayment ? "d-none" : "")">
                        <label class="clinical-field-label">Patient Barcode</label>
                        <input asp-for="Input.PatientId" id="cashPaymentPatientBarcodeInput" class="clinical-field patient-barcode-input" placeholder="Scan or type barcode..." autocomplete="off" />
                    </div>
                    <div class="col-md-1 patient-payment-fields @(Model.IsVendorPayment ? "d-none" : "")">
                        <label class="clinical-field-label">Age</label>
                        <input asp-for="Input.Age" class="clinical-field" type="number" readonly />
                    </div>
                    <div class="col-md-2 patient-payment-fields @(Model.IsVendorPayment ? "d-none" : "")">
                        <label class="clinical-field-label">Gender</label>
                        <input asp-for="Input.Gender" class="clinical-field" readonly />
                    </div>
                    <div class="col-md-3 patient-payment-fields @(Model.IsVendorPayment ? "d-none" : "")">
                        <label class="clinical-field-label">Phone</label>
                        <input asp-for="Input.Phone" class="clinical-field" readonly />
                    </div>
                    <div class="col-md-3 patient-payment-fields @(Model.IsVendorPayment ? "d-none" : "")">
                        <label class="clinical-field-label">City</label>
                        <input asp-for="Input.City" class="clinical-field" readonly />
                    </div>
                    <div class="col-md-4 patient-payment-fields @(Model.IsVendorPayment ? "d-none" : "")">
                        <label class="clinical-field-label">Doctor Name</label>
                        <input asp-for="Input.DoctorName" class="clinical-field" readonly />
                    </div>
                    <div class="col-md-4 patient-payment-fields @(Model.IsVendorPayment ? "d-none" : "")">
                        <label class="clinical-field-label">Specialty</label>
                        <input asp-for="Input.Specialty" class="clinical-field" readonly />
                    </div>
                    <div class="col-md-3 patient-payment-fields @(Model.IsVendorPayment ? "d-none" : "")">
                        <label class="clinical-field-label">Balance Due</label>
                        <input asp-for="Input.BalanceDue" class="clinical-field" type="number" step="0.01" />
                    </div>
                    <div class="col-md-3 patient-payment-fields @(Model.IsVendorPayment ? "d-none" : "")">
                        <label class="clinical-field-label">Balance Status</label>
                        <input asp-for="Input.BalanceStatus" class="clinical-field" />
                    </div>
                    <div class="col-md-3">
                        <label class="clinical-field-label field-required">Amount</label>
                        <input asp-for="Input.Amount" class="clinical-field" type="number" step="0.01" required />
                        <span asp-validation-for="Input.Amount" class="text-danger small"></span>
                    </div>
                    <div class="col-md-3">
                        <label class="clinical-field-label field-required">Payment Method</label>
                        <select asp-for="Input.PaymentMethod" id="cashPaymentMethodSelect" class="clinical-field" required>
                            @if (Model.IsVendorPayment)
                            {
                                @foreach (var m in AtoZClinical.Infrastructure.Services.ClinicLookup.VendorPaymentMethods)
                                {
                                    <option value="@m" selected="@(Model.Input.PaymentMethod == m ? "selected" : null)">@m</option>
                                }
                            }
                            else
                            {
                                @foreach (var m in AtoZClinical.Infrastructure.Services.ClinicLookup.PaymentMethods)
                                {
                                    <option value="@m" selected="@(Model.Input.PaymentMethod == m ? "selected" : null)">@m</option>
                                }
                            }
                        </select>
                        <span asp-validation-for="Input.PaymentMethod" class="text-danger small"></span>
                    </div>
                    <div class="col-md-3 patient-payment-fields @(Model.IsVendorPayment ? "d-none" : "")">
                        <label class="clinical-field-label">Ending Balance</label>
                        <input asp-for="Input.EndingBalance" class="clinical-field" type="number" step="0.01" readonly />
                    </div>
                    <div class="col-md-6">
                        <label class="clinical-field-label field-required">@(Model.IsVendorPayment ? "Expense Account" : "Account Name")</label>
                        <select asp-for="Input.ChartAccountName" id="cashPaymentAccountSelect" class="clinical-field" required>
                            <option value="">-- Select Account --</option>
                            @if (Model.IsVendorPayment)
                            {
                                @foreach (var a in Model.ExpenseAccounts)
                                {
                                    <option value="@a.Name" selected="@(Model.Input.ChartAccountName == a.Name ? "selected" : null)">@a.AccountNo — @a.Name</option>
                                }
                            }
                            else
                            {
                                @foreach (var group in Model.Accounts.GroupBy(a => a.CategoryType).OrderBy(g => g.Key))
                                {
                                    <optgroup label="@group.Key">
                                    @foreach (var a in group.OrderBy(a => a.AccountNo))
                                    {
                                        <option value="@a.Name" selected="@(Model.Input.ChartAccountName == a.Name ? "selected" : null)">@a.AccountNo — @a.Name</option>
                                    }
                                    </optgroup>
                                }
                            }
                            @if (!string.IsNullOrWhiteSpace(Model.Input.ChartAccountName) &&
                                 !Model.Accounts.Any(a => a.Name == Model.Input.ChartAccountName) &&
                                 !Model.ExpenseAccounts.Any(a => a.Name == Model.Input.ChartAccountName))
                            {
                                <option value="@Model.Input.ChartAccountName" selected>@Model.Input.ChartAccountName</option>
                            }
                        </select>
                        <span asp-validation-for="Input.ChartAccountName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-3">
                        <label class="clinical-field-label">Written Amount</label>
                        <input asp-for="Input.WrittenAmount" class="clinical-field" />
                    </div>
                    <div class="col-md-3">
                        <label class="clinical-field-label">Reference No</label>
                        <input asp-for="Input.ReferenceNo" class="clinical-field" />
                    </div>
                    <div class="col-md-12">
                        <label class="clinical-field-label">Description</label>
                        <textarea asp-for="Input.Description" class="clinical-field" rows="3"></textarea>
                    </div>
                </div>
                </div>
            </div>
            <div class="clinical-form-right">
                <div class="record-transaction-header">Record Transaction</div>
                <div class="record-transaction-status">@Model.StatusText</div>
                <div class="p-2">
                    <input id="searchBox" name="Search" value="@Model.Search" class="clinical-field mb-2" placeholder="Search..." />
                </div>
                <div class="line-grid-scroll clinical-record-grid-scroll">
                    <table class="line-grid">
                        <thead><tr><th>ID</th><th>Date</th><th>Patie...</th><th>Doctor</th><th>Acco...</th><th>A...</th></tr></thead>
                        <tbody>
                        @foreach (var r in Model.Records)
                        {
                            <tr class="@(Model.RecordId == r.Id ? "selected" : "")" onclick="location.href='?RecordId=@r.Id'">
                                <td>@r.PaymentNo</td>
                                <td>@r.PaymentDate.ToString("d")</td>
                                <td>@r.PayeeName</td>
                                <td>@r.DoctorName</td>
                                <td>@r.ChartAccountName</td>
                                <td>@r.Amount.ToString("N2")</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <input type="hidden" asp-for="RecordId" />
        <partial name="_FormToolbar" />
        <div class="clinical-form-footer">
            <span>Created By: @Model.UserName</span>
            <span>Last Updated By: @Model.UserName</span>
        </div>
    </form>
</div>

<partial name="_PatientSelectModal" />

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        window.cashPaymentExpenseAccounts = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            Model.ExpenseAccounts.Select(a => new { a.AccountNo, Name = a.Name })));
        window.cashPaymentAllAccounts = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            Model.Accounts.Select(a => new { a.AccountNo, Name = a.Name, CategoryType = a.CategoryType })));
    </script>
    <script src="~/js/amount-words.js" asp-append-version="true"></script>
    <script src="~/js/cash-balance.js" asp-append-version="true"></script>
    <script src="~/js/patient-picker.js" asp-append-version="true"></script>
    <script src="~/js/cash-payment.js" asp-append-version="true"></script>
    <script src="~/js/cash-payment-vendor.js" asp-append-version="true"></script>
}
