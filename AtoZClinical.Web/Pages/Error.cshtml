@page
@model ErrorModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Error - A to Z Clinical</title>
    <style>
        body { font-family: Segoe UI, sans-serif; background: #f5f7fa; margin: 0; padding: 2rem; }
        .card { max-width: 640px; margin: 0 auto; background: #fff; border-radius: 8px; padding: 1.5rem; box-shadow: 0 1px 4px rgba(0,0,0,.08); }
        h1 { color: #b00020; margin-top: 0; }
        .muted { color: #555; }
        a { color: #0b4f8a; }
        code { background: #f0f0f0; padding: 2px 6px; border-radius: 4px; }
    </style>
</head>
<body>
<div class="card">
    <h1>Something went wrong</h1>
    <p class="muted">An unexpected error occurred while processing your request. Please try again.</p>
    @if (Model.ShowRequestId)
    {
        <p class="muted"><strong>Reference:</strong> <code>@Model.RequestId</code></p>
    }
    <p><a href="/Account/Login">Sign in</a> &nbsp;|&nbsp; <a href="/">Home</a></p>
</div>
</body>
</html>
