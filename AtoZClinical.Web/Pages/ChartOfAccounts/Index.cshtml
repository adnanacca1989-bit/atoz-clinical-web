@page
@model AtoZClinical.Web.Pages.ChartOfAccounts.IndexModel
@{
    ViewData["Title"] = "Chart of Accounts";
    Layout = "_Layout";
}

<div class="clinical-form-page">
    <h1 class="page-title">Chart of Accounts</h1>
    <form method="post">
        <div class="clinical-form-body">
            <div class="clinical-form-left">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="clinical-field-label">GL Account No</label>
                        <input asp-for="Input.AccountNo" class="clinical-field" />
                    </div>
                    <div class="col-md-9">
                        <label class="clinical-field-label">Name <span class="text-danger">*</span></label>
                        <input asp-for="Input.Name" class="clinical-field" />
                    </div>
                    <div class="col-md-6">
                        <label class="clinical-field-label">Category Type</label>
                        <select asp-for="Input.CategoryType" id="chartCategoryType" class="clinical-field" asp-items="@(new SelectList(AtoZClinical.Infrastructure.Services.ClinicLookup.AccountCategoryTypes))"></select>
                    </div>
                    <div class="col-md-6">
                        <label class="clinical-field-label">Detail Type <span class="text-danger">*</span></label>
                        <select asp-for="Input.DetailType" id="chartDetailType" class="clinical-field">
                            <option value="">--</option>
                            @foreach (var detailType in Model.DetailTypeOptions)
                            {
                                <option value="@detailType" selected="@(Model.Input.DetailType == detailType)">@detailType</option>
                            }
                            @if (!string.IsNullOrWhiteSpace(Model.Input.DetailType) && !Model.DetailTypeOptions.Contains(Model.Input.DetailType, StringComparer.OrdinalIgnoreCase))
                            {
                                <option value="@Model.Input.DetailType" selected>@Model.Input.DetailType</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-12">
                        <label class="clinical-field-label">Description</label>
                        <input asp-for="Input.Description" class="clinical-field" />
                    </div>
                </div>
            </div>
            <div class="clinical-form-right">
                <div class="record-transaction-header">Account List</div>
                <div class="record-transaction-status">@Model.StatusText</div>
                <div class="p-2">
                    <input id="searchBox" name="Search" value="@Model.Search" class="clinical-field mb-2" placeholder="Search..." />
                </div>
                <div class="clinical-record-grid">
                    <table>
                        <thead><tr><th>GL No</th><th>Cate...</th><th>Detail Type</th><th>Name</th><th>Des...</th></tr></thead>
                        <tbody>
                        @foreach (var r in Model.Records)
                        {
                            <tr class="@(Model.RecordId == r.Id ? "selected" : "")" onclick="location.href='?RecordId=@r.Id'">
                                <td>@r.AccountNo</td>
                                <td>@r.CategoryType</td>
                                <td>@r.DetailType</td>
                                <td>@r.Name</td>
                                <td>@r.Description</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <input type="hidden" asp-for="RecordId" />
        <partial name="_FormToolbar" />
        <div class="clinical-form-footer">
            <span>Created By: @Model.UserName</span>
            <span>Last Updated By: @Model.UserName</span>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        window.chartAccountDetailTypes = @Html.Raw(Model.DetailTypesByCategoryJson);
    </script>
    <script src="~/js/chart-of-accounts.js" asp-append-version="true"></script>
}
