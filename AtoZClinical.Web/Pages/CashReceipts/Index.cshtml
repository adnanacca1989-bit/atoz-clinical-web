@page
@model AtoZClinical.Web.Pages.CashReceipts.IndexModel
@{
    ViewData["Title"] = "Cash Receipt";
    Layout = "_Layout";
}

<div class="clinical-form-page">
    <h1 class="page-title">Cash Receipt</h1>
    <form method="post">
        <div class="clinical-form-body">
            <div class="clinical-form-left">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="clinical-field-label">Receipt No</label>
                        <input asp-for="Input.ReceiptNo" class="clinical-field" readonly />
                    </div>
                    <div class="col-md-3">
                        <label class="clinical-field-label">Date</label>
                        <input asp-for="Input.ReceiptDate" class="clinical-field" type="date" />
                    </div>
                    <div class="col-md-6">
                        <label class="clinical-field-label">Patient Search</label>
                        <input asp-for="Input.PatientSearch" class="clinical-field" />
                    </div>
                    <div class="col-md-6">
                        <label class="clinical-field-label">Patient Name</label>
                        <input asp-for="Input.PatientName" class="clinical-field" />
                    </div>
                    <div class="col-md-6">
                        <label class="clinical-field-label">Patient ID</label>
                        <input asp-for="Input.PatientId" class="clinical-field" />
                    </div>
                    <div class="col-md-4">
                        <label class="clinical-field-label">Appointment Date</label>
                        <input asp-for="Input.AppointmentDate" class="clinical-field" type="date" />
                    </div>
                    <div class="col-md-4">
                        <label class="clinical-field-label">Appointment Time</label>
                        <input asp-for="Input.AppointmentTime" class="clinical-field" type="time" />
                    </div>
                    <div class="col-md-4">
                        <label class="clinical-field-label">Doctor Name</label>
                        <input asp-for="Input.DoctorName" class="clinical-field" />
                    </div>
                    <div class="col-md-3">
                        <label class="clinical-field-label">Balance Due</label>
                        <input asp-for="Input.BalanceDue" class="clinical-field" type="number" step="0.01" />
                    </div>
                    <div class="col-md-3">
                        <label class="clinical-field-label">Balance Status</label>
                        <input asp-for="Input.BalanceStatus" class="clinical-field" />
                    </div>
                    <div class="col-md-3">
                        <label class="clinical-field-label">Ending Balance</label>
                        <input asp-for="Input.EndingBalance" class="clinical-field" type="number" step="0.01" />
                    </div>
                    <div class="col-md-3">
                        <label class="clinical-field-label">Amount</label>
                        <input asp-for="Input.Amount" class="clinical-field" type="number" step="0.01" />
                    </div>
                    <div class="col-md-6">
                        <label class="clinical-field-label">Written Amount</label>
                        <input asp-for="Input.WrittenAmount" class="clinical-field" />
                    </div>
                    <div class="col-md-3">
                        <label class="clinical-field-label">Payment Method</label>
                        <select asp-for="Input.PaymentMethod" class="clinical-field" asp-items="@(new SelectList(AtoZClinical.Infrastructure.Services.ClinicLookup.PaymentMethods))"></select>
                    </div>
                    <div class="col-md-3">
                        <label class="clinical-field-label">Reference No</label>
                        <input asp-for="Input.ReferenceNo" class="clinical-field" />
                    </div>
                    <div class="col-md-12">
                        <label class="clinical-field-label">Description</label>
                        <input asp-for="Input.Description" class="clinical-field" />
                    </div>
                </div>
            </div>
            <div class="clinical-form-right">
                <div class="record-transaction-header">Record Transaction</div>
                <div class="record-transaction-status">@Model.StatusText</div>
                <div class="p-2">
                    <input id="searchBox" name="Search" value="@Model.Search" class="clinical-field mb-2" placeholder="Search..." />
                </div>
                <div class="clinical-record-grid">
                    <table>
                        <thead><tr><th>ID</th><th>Date</th><th>Patient I...</th><th>Patie...</th><th>Appoint</th></tr></thead>
                        <tbody>
                        @foreach (var r in Model.Records)
                        {
                            <tr class="@(Model.RecordId == r.Id ? "selected" : "")" onclick="location.href='?RecordId=@r.Id'">
                                <td>@r.ReceiptNo</td>
                                <td>@r.ReceiptDate.ToString("d")</td>
                                <td>@r.PatientId</td>
                                <td>@r.PatientName</td>
                                <td>@(r.AppointmentDate?.ToString("d") ?? "")</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <input type="hidden" asp-for="RecordId" />
        <partial name="_FormToolbar" />
        <div class="clinical-form-footer">
            <span>Created By: @Model.UserName</span>
            <span>Last Updated By: @Model.UserName</span>
        </div>
    </form>
</div>
