@page
@model AtoZClinical.Web.Pages.Prescriptions.IndexModel
@{
    ViewData["Title"] = "Doctor's Prescription";
    Layout = "_Layout";
    ViewData["FormHint"] = "Select patient first — age, gender, doctor, and specialty populate automatically. Choose medications from pharmacy registration (display only). Complete diagnosis text before saving.";
}

<div class="clinical-form-page clinical-standard-form prescription-his-layout prescription-expanded">
    <h1 class="page-title">Doctor's Prescription</h1>
    <div asp-validation-summary="All" class="validation-summary-errors"></div>
    <partial name="_ClinicalFormHint" />
    <form method="post">
        <div class="clinical-form-body">
            <div class="clinical-form-left clinical-form-scroll prescription-clinical-block">
                <div class="clinical-context-strip">
                    <div class="ctx-row">
                        <div class="ctx-field ctx-doc"><label class="clinical-field-label">Rx No</label><input asp-for="Input.PrescriptionNo" class="clinical-field" readonly /></div>
                        <div class="ctx-field ctx-date"><label class="clinical-field-label field-required">Date</label><input asp-for="Input.DatePrescription" class="clinical-field" type="date" required /><span asp-validation-for="Input.DatePrescription" class="text-danger small"></span></div>
                        <div class="ctx-field ctx-patient">
                            <label class="clinical-field-label field-required">Patient Name</label>
                            <input asp-for="Input.PatientName" id="prescriptionPatientNameInput" class="clinical-field doctor-picker-field" readonly placeholder="Click to select patient..." />
                            <span asp-validation-for="Input.PatientName" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="ctx-row ctx-demographics">
                        <div class="ctx-field ctx-sm"><label class="clinical-field-label">MRN / Barcode</label><input asp-for="Input.PatientBarcode" id="prescriptionPatientBarcodeInput" class="clinical-field patient-barcode-input" placeholder="Scan barcode..." autocomplete="off" /></div>
                        <div class="ctx-field ctx-xs"><label class="clinical-field-label field-required">Age</label><input asp-for="Input.Age" id="prescriptionAgeInput" class="clinical-field" type="number" readonly /><span asp-validation-for="Input.Age" class="text-danger small"></span></div>
                        <div class="ctx-field ctx-xs"><label class="clinical-field-label field-required">Sex</label><select asp-for="Input.Gender" class="clinical-field" required><option>Male</option><option>Female</option></select><span asp-validation-for="Input.Gender" class="text-danger small"></span></div>
                        <div class="ctx-field ctx-lg"><label class="clinical-field-label field-required">Doctor</label><input asp-for="Input.DoctorName" id="prescriptionDoctorNameInput" class="clinical-field" readonly /><span asp-validation-for="Input.DoctorName" class="text-danger small"></span></div>
                        <div class="ctx-field ctx-md"><label class="clinical-field-label field-required">Specialty</label><input asp-for="Input.Specialty" id="prescriptionSpecialtyInput" class="clinical-field" readonly /><span asp-validation-for="Input.Specialty" class="text-danger small"></span></div>
                        <div class="ctx-field ctx-grow"><label class="clinical-field-label field-required">Disease</label><input asp-for="Input.DiseaseName" class="clinical-field" required /><span asp-validation-for="Input.DiseaseName" class="text-danger small"></span></div>
                    </div>
                </div>
                <div class="section-caption">Chronic Diseases</div>
                <div class="prescription-chronic-scroll">
                    <table class="line-grid clinical-line-grid">
                        <thead><tr><th>Chronic Disease Type</th><th>Details</th></tr></thead>
                        <tbody>
                        @for (var i = 0; i < Model.ChronicDiseases.Count; i++)
                        {
                            <tr>
                                <td><input asp-for="ChronicDiseases[i].DiseaseType" readonly /></td>
                                <td><input asp-for="ChronicDiseases[i].Details" /></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
                <div class="prescription-diagnosis-block">
                    <label class="clinical-field-label field-required">Diagnosis Text</label>
                    <textarea asp-for="Input.DiagnosisText" class="clinical-field" rows="3" required></textarea>
                    <span asp-validation-for="Input.DiagnosisText" class="text-danger small"></span>
                </div>
                <div class="clinical-form-grid-area prescription-medication-area">
                    <div class="section-caption">Medications</div>
                    <div class="line-grid-scroll prescription-medication-scroll">
                        <table class="line-grid clinical-line-grid prescription-medication-grid">
                            <thead>
                                <tr>
                                    <th class="col-no">#</th>
                                    <th class="col-medication">Medication</th>
                                    <th class="col-from">From</th>
                                    <th class="col-dose">Dose</th>
                                    <th class="col-unit">Unit</th>
                                    <th class="col-frequency">Frequency</th>
                                    <th class="col-duration">Duration</th>
                                    <th class="col-instruction">Instruction</th>
                                    <th class="col-del">Del</th>
                                </tr>
                            </thead>
                            <tbody>
                            @for (var i = 0; i < Model.Medications.Count; i++)
                            {
                                var medItemId = Model.Medications[i].PharmacyItemId;
                                <tr class="prescription-line" data-line="@i">
                                    <td><input asp-for="Medications[i].LineNo" readonly /></td>
                                    <td class="col-medication">
                                        <input type="hidden" asp-for="Medications[i].PharmacyItemId" class="prescription-pharmacy-id" />
                                        <input type="hidden" asp-for="Medications[i].MedicineName" class="prescription-medicine-name" />
                                        <select class="prescription-item-select clinical-field">
                                            <option value="">-- Medication --</option>
                                            @foreach (var item in Model.RegisteredItems)
                                            {
                                                <option value="@item.Id" selected="@(medItemId == item.Id ? "selected" : null)" data-name="@item.MedicineName" data-dosage="@item.Dosage" data-base-uom="@item.BaseUom">@item.MedicineName</option>
                                            }
                                        </select>
                                    </td>
                                    <td><input asp-for="Medications[i].MedicationForm" class="prescription-med-form" placeholder="Form" /></td>
                                    <td><input asp-for="Medications[i].Dose" class="prescription-dose" placeholder="Dose" /></td>
                                    <td><input asp-for="Medications[i].Unit" class="prescription-unit" placeholder="Unit" /></td>
                                    <td><input asp-for="Medications[i].Frequency" placeholder="e.g. BID" /></td>
                                    <td><input asp-for="Medications[i].Duration" placeholder="e.g. 7 days" /></td>
                                    <td><input asp-for="Medications[i].Instruction" class="prescription-instruction" placeholder="Instructions" /></td>
                                    <td class="col-del text-center"><button type="button" class="btn-form delete-line-btn" title="Delete line">🗑</button></td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="clinical-form-right">
                <div class="record-transaction-header">Record Transaction</div>
                <div class="record-transaction-status">@Model.StatusText</div>
                <div class="p-2">
                    <input id="searchBox" name="Search" value="@Model.Search" class="clinical-field mb-2" placeholder="Search..." />
                </div>
                <div class="clinical-record-grid">
                    <table>
                        <thead><tr><th>Rx No</th><th>Date</th><th>Patient</th><th>Doctor</th></tr></thead>
                        <tbody>
                        @foreach (var r in Model.Records)
                        {
                            <tr class="@(Model.RecordId == r.Id ? "selected" : "")" onclick="location.href='?RecordId=@r.Id'">
                                <td>@r.PrescriptionNo</td>
                                <td>@r.DatePrescription.ToString("d")</td>
                                <td>@r.PatientName</td>
                                <td>@r.DoctorName</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <input type="hidden" asp-for="RecordId" />
        <partial name="_FormToolbar" />
        <div class="clinical-form-footer">
            <span>Created By: @Model.UserName</span>
            <span>Last Updated By: @Model.UserName</span>
        </div>
    </form>
</div>

<partial name="_PatientSelectModal" />

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/clinical-line-grid.js" asp-append-version="true"></script>
    <script src="~/js/prescriptions.js" asp-append-version="true"></script>
    <script src="~/js/prescription-medications.js" asp-append-version="true"></script>
}
