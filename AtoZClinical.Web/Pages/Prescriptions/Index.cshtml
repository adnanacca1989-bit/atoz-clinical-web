@page

@model AtoZClinical.Web.Pages.Prescriptions.IndexModel

@{

    ViewData["Title"] = "Doctor's Prescription";

    Layout = "_Layout";

}



<div class="clinical-form-page">

    <h1 class="page-title">Doctor's Prescription</h1>

    <div asp-validation-summary="All" class="validation-summary-errors mx-3"></div>

    <form method="post">

        <div class="clinical-form-body">

            <div class="clinical-form-left">

                <div class="row g-3 mb-2">

                    <div class="col-md-3">

                        <label class="clinical-field-label">ID Prescription</label>

                        <input asp-for="Input.PrescriptionNo" class="clinical-field" readonly />

                    </div>

                    <div class="col-md-3">

                        <label class="clinical-field-label field-required">Patient Name</label>

                        <input asp-for="Input.PatientName" id="prescriptionPatientNameInput" class="clinical-field doctor-picker-field" readonly placeholder="Click to select patient..." required />

                        <span asp-validation-for="Input.PatientName" class="text-danger small"></span>

                    </div>

                    <div class="col-md-3">

                        <label class="clinical-field-label field-required">Age</label>

                        <input asp-for="Input.Age" id="prescriptionAgeInput" class="clinical-field" type="number" readonly required />

                        <span asp-validation-for="Input.Age" class="text-danger small"></span>

                    </div>

                    <div class="col-md-3">

                        <label class="clinical-field-label field-required">Gender</label>

                        <select asp-for="Input.Gender" class="clinical-field" required>

                            <option>Male</option>

                            <option>Female</option>

                        </select>

                        <span asp-validation-for="Input.Gender" class="text-danger small"></span>

                    </div>

                    <div class="col-md-4">

                        <label class="clinical-field-label field-required">Doctor Name</label>

                        <input asp-for="Input.DoctorName" id="prescriptionDoctorNameInput" class="clinical-field" readonly required />

                        <span asp-validation-for="Input.DoctorName" class="text-danger small"></span>

                    </div>

                    <div class="col-md-4">

                        <label class="clinical-field-label field-required">Specialty</label>

                        <input asp-for="Input.Specialty" id="prescriptionSpecialtyInput" class="clinical-field" readonly required />

                        <span asp-validation-for="Input.Specialty" class="text-danger small"></span>

                    </div>

                    <div class="col-md-4">

                        <label class="clinical-field-label field-required">Date Prescription</label>

                        <input asp-for="Input.DatePrescription" class="clinical-field" type="date" required />

                        <span asp-validation-for="Input.DatePrescription" class="text-danger small"></span>

                    </div>

                    <div class="col-md-12">

                        <label class="clinical-field-label field-required">Name of Disease</label>

                        <input asp-for="Input.DiseaseName" class="clinical-field" required />

                        <span asp-validation-for="Input.DiseaseName" class="text-danger small"></span>

                    </div>

                </div>

                <div class="section-caption">Chronic Diseases</div>

                <div class="line-grid-scroll">
                <table class="line-grid clinical-line-grid">

                    <thead><tr><th>Chronic Disease Type</th><th>Details</th></tr></thead>

                    <tbody>

                    @for (var i = 0; i < Model.ChronicDiseases.Count; i++)

                    {

                        <tr>

                            <td>

                                <input asp-for="ChronicDiseases[i].DiseaseType" readonly />

                            </td>

                            <td><input asp-for="ChronicDiseases[i].Details" /></td>

                        </tr>

                    }

                    </tbody>

                </table>
                </div>

            </div>

            <div class="clinical-form-right">

                <div class="record-transaction-header">Record Transaction</div>

                <div class="record-transaction-status">@Model.StatusText</div>

                <div class="p-2">

                    <input id="searchBox" name="Search" value="@Model.Search" class="clinical-field mb-2" placeholder="Search..." />

                </div>

                <div class="clinical-record-grid" style="max-height: 180px;">

                    <table>

                        <thead><tr><th>ID</th><th>Date</th><th>Patie...</th><th>Doctor</th><th>Specialty</th></tr></thead>

                        <tbody>

                        @foreach (var r in Model.Records)

                        {

                            <tr class="@(Model.RecordId == r.Id ? "selected" : "")" onclick="location.href='?RecordId=@r.Id'">

                                <td>@r.PrescriptionNo</td>

                                <td>@r.DatePrescription.ToString("d")</td>

                                <td>@r.PatientName</td>

                                <td>@r.DoctorName</td>

                                <td>@r.Specialty</td>

                            </tr>

                        }

                        </tbody>

                    </table>

                </div>

                <div class="section-caption mt-3 field-required">Diagnosis Text</div>

                <textarea asp-for="Input.DiagnosisText" class="clinical-field" rows="6" style="width:100%;" required></textarea>

                <span asp-validation-for="Input.DiagnosisText" class="text-danger small"></span>

            </div>

        </div>

        <input type="hidden" asp-for="RecordId" />

        <partial name="_FormToolbar" />

        <div class="clinical-form-footer">

            <span>Created By: @Model.UserName</span>

            <span>Last Updated By: @Model.UserName</span>

        </div>

    </form>

</div>



<partial name="_PatientSelectModal" />



@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script src="~/js/prescriptions.js" asp-append-version="true"></script>

}


