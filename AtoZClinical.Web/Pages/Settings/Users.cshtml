@page
@model AtoZClinical.Web.Pages.Settings.UsersModel
@using AtoZClinical.Core.Enums
@{
    ViewData["Title"] = "Define User";
    Layout = "_Layout";
    var isDoctorRole = Model.Input.Role == ClinicUserRole.Doctor;
}

<div class="clinical-form-page">
    <h1 class="page-title">Define User</h1>
    <partial name="_SettingsMenu" />
    <form method="post" id="defineUserForm">
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
        <div class="clinical-form-body">
            <div class="clinical-form-left">
                <div class="row g-3">
                    <div class="col-md-2">
                        <label class="clinical-field-label">User ID</label>
                        <input asp-for="Input.UserNo" class="clinical-field" readonly />
                    </div>
                    <div class="col-md-3">
                        <label class="clinical-field-label">Username *</label>
                        <input asp-for="Input.Username" class="clinical-field" readonly="@(!Model.IsNewUser)" />
                    </div>
                    <div class="col-md-4">
                        <label class="clinical-field-label" id="fullNameLabel">@(isDoctorRole ? "Doctor (name & specialty) *" : "Full Name *")</label>
                        <div class="input-group">
                            <input asp-for="Input.FullName"
                                   id="userFullNameInput"
                                   class="clinical-field @(isDoctorRole ? "doctor-picker-field" : "")"
                                   readonly="@isDoctorRole"
                                   placeholder="@(isDoctorRole ? "Click to select doctor" : null)"
                                   autocomplete="off" />
                            <button type="button"
                                    class="btn btn-outline-secondary @(isDoctorRole ? "" : "d-none")"
                                    id="openDoctorSelectBtn"
                                    title="Select doctor">Select</button>
                        </div>
                        <input type="hidden" asp-for="Input.DoctorRecordId" id="userDoctorRecordId" />
                    </div>
                    <div class="col-md-3">
                        <label class="clinical-field-label">Email</label>
                        <input asp-for="Input.Email" class="clinical-field" type="email" />
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <div class="form-check mb-2">
                            <input asp-for="Input.IsActive" class="form-check-input" type="checkbox" />
                            <label class="form-check-label" asp-for="Input.IsActive">Active</label>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <label class="clinical-field-label">Password</label>
                        <input asp-for="Input.Password" class="clinical-field" type="password" placeholder="@(Model.IsNewUser ? "Required" : "Leave blank to keep")" />
                    </div>
                    <div class="col-md-3">
                        <label class="clinical-field-label">Role</label>
                        <select asp-for="Input.Role" class="clinical-field" id="userRoleSelect">
                            @foreach (var role in AtoZClinical.Infrastructure.Services.ClinicUserRoleHelper.DefineUserRoles)
                            {
                                <option value="@((int)role.Value)">@role.Label</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
            <div class="clinical-form-right">
                <div class="record-transaction-header">Record Transaction</div>
                <div class="record-transaction-status">@Model.StatusText</div>
                <div class="p-2">
                    <input id="searchBox" name="Search" value="@Model.Search" class="clinical-field mb-2" placeholder="Search..." />
                </div>
                <div class="clinical-record-grid">
                    <table>
                        <thead><tr><th>User ID</th><th>Username</th><th>Full Name</th><th>Role</th><th>Active</th></tr></thead>
                        <tbody>
                        @foreach (var r in Model.Records)
                        {
                            <tr class="@(Model.UserRecordId == r.Id ? "selected" : "")" onclick="location.href='?UserRecordId=@r.Id'">
                                <td>@r.UserNo</td>
                                <td>@r.UserName</td>
                                <td>@r.FullName</td>
                                <td>@AtoZClinical.Infrastructure.Services.ClinicUserRoleHelper.GetLabel(r.ClinicRole ?? AtoZClinical.Core.Enums.ClinicUserRole.Receptionist)</td>
                                <td>@(r.IsActive ? "Yes" : "No")</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <input type="hidden" name="UserRecordId" value="@Model.UserRecordId" />
        <partial name="_FormToolbar" />
    </form>
</div>

<partial name="_DoctorSelectModal" />

@section Scripts {
    <script src="~/js/doctor-picker.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const roleSelect = document.getElementById('userRoleSelect');
            const fullNameInput = document.getElementById('userFullNameInput');
            const fullNameLabel = document.getElementById('fullNameLabel');
            const doctorRecordIdInput = document.getElementById('userDoctorRecordId');
            const openDoctorBtn = document.getElementById('openDoctorSelectBtn');
            if (!roleSelect || !fullNameInput || !doctorRecordIdInput) return;

            const doctorRole = '@((int)ClinicUserRole.Doctor)';
            let pickerReady = false;

            const isDoctorRole = () => roleSelect.value === doctorRole;

            const formatDoctorLabel = (d) => {
                if (!d) return '';
                return d.specialty ? `${d.name} — ${d.specialty}` : (d.name || '');
            };

            const openDoctorPicker = () => openDoctorBtn?.click();

            const ensurePicker = () => {
                if (pickerReady) return;
                initDoctorPicker({
                    doctorNameSelector: '#userFullNameInput',
                    openButtonId: 'openDoctorSelectBtn',
                    fieldMap: { '#userDoctorRecordId': d => d.id },
                    onApply: (d) => { fullNameInput.value = formatDoctorLabel(d); }
                });
                pickerReady = true;
            };

            const setDoctorMode = (autoOpen) => {
                const doctor = isDoctorRole();
                fullNameLabel.textContent = doctor ? 'Doctor (name & specialty) *' : 'Full Name *';
                fullNameInput.readOnly = doctor;
                fullNameInput.classList.toggle('doctor-picker-field', doctor);
                fullNameInput.placeholder = doctor ? 'Click to select doctor' : '';
                openDoctorBtn?.classList.toggle('d-none', !doctor);

                if (doctor) {
                    ensurePicker();
                    if (autoOpen && !doctorRecordIdInput.value) {
                        setTimeout(openDoctorPicker, 200);
                    }
                } else {
                    doctorRecordIdInput.value = '';
                }
            };

            roleSelect.addEventListener('change', () => {
                if (!isDoctorRole()) {
                    fullNameInput.value = '';
                    doctorRecordIdInput.value = '';
                    setDoctorMode(false);
                } else {
                    fullNameInput.value = '';
                    setDoctorMode(true);
                }
            });

            fullNameInput.addEventListener('keydown', (e) => {
                if (isDoctorRole()) e.preventDefault();
            });
            fullNameInput.addEventListener('paste', (e) => {
                if (isDoctorRole()) e.preventDefault();
            });

            if (isDoctorRole()) ensurePicker();
            setDoctorMode(false);
        });
    </script>
}
