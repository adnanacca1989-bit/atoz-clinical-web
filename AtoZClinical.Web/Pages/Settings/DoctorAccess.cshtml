@page
@model AtoZClinical.Web.Pages.Settings.DoctorAccessModel
@{
    ViewData["Title"] = "Doctor Access";
    Layout = "_Layout";
}

<div class="clinical-form-page">
    <h1 class="page-title">Doctor Access</h1>
    <partial name="_SettingsMenu" />

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-success">@Model.StatusMessage</div>
    }

    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
        <div class="atz-card p-4">
            <p class="text-muted mb-3">
                Control whether doctors can view patients assigned to other doctors. Only clinic administrators can change this setting.
            </p>
            <div class="form-check form-switch">
                <input asp-for="AllowDoctorViewAllPatients" class="form-check-input" type="checkbox" role="switch" />
                <label class="form-check-label" asp-for="AllowDoctorViewAllPatients">
                    Allow doctor to view other doctors' patients
                </label>
            </div>
            <p class="small text-muted mt-3 mb-0">
                When disabled, each doctor sees only patients linked to their user account (or matching doctor name). Lab, radiology, pharmacy, and reception staff are not restricted.
            </p>
        </div>
        <div class="mt-3">
            <button type="submit" class="btn btn-primary">Save</button>
        </div>
    </form>
</div>
