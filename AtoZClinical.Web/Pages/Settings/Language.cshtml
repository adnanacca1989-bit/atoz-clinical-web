@page
@model AtoZClinical.Web.Pages.Settings.LanguageModel
@{
    ViewData["Title"] = "Define Language";
    Layout = "_Layout";
}

<div class="clinical-form-page">
    <h1 class="page-title">Define Language</h1>
    <partial name="_SettingsMenu" />
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
        <div class="clinical-form-body">
            <div class="clinical-form-left">
                <div class="row g-3">
                    <div class="col-md-2">
                        <label class="clinical-field-label">ID</label>
                        <input asp-for="Input.LanguageNo" class="clinical-field" readonly />
                    </div>
                    <div class="col-md-3">
                        <label class="clinical-field-label">Code *</label>
                        <input asp-for="Input.Code" class="clinical-field" placeholder="en" />
                    </div>
                    <div class="col-md-4">
                        <label class="clinical-field-label">Language Name</label>
                        <input asp-for="Input.Name" class="clinical-field" placeholder="English" />
                    </div>
                    <div class="col-md-3 d-flex align-items-end gap-3">
                        <div class="form-check mb-2">
                            <input asp-for="Input.IsDefault" class="form-check-input" type="checkbox" />
                            <label class="form-check-label" asp-for="Input.IsDefault">Default</label>
                        </div>
                        <div class="form-check mb-2">
                            <input asp-for="Input.IsActive" class="form-check-input" type="checkbox" />
                            <label class="form-check-label" asp-for="Input.IsActive">Active</label>
                        </div>
                    </div>
                </div>
            </div>
            <div class="clinical-form-right">
                <div class="record-transaction-header">Record Transaction</div>
                <div class="record-transaction-status">@Model.StatusText</div>
                <div class="p-2">
                    <input id="searchBox" name="Search" value="@Model.Search" class="clinical-field mb-2" placeholder="Search..." />
                </div>
                <div class="clinical-record-grid">
                    <table>
                        <thead><tr><th>ID</th><th>Code</th><th>Name</th><th>Default</th></tr></thead>
                        <tbody>
                        @foreach (var r in Model.Records)
                        {
                            <tr class="@(Model.RecordId == r.Id ? "selected" : "")" onclick="location.href='?RecordId=@r.Id'">
                                <td>@r.LanguageNo</td>
                                <td>@r.Code</td>
                                <td>@r.Name</td>
                                <td>@(r.IsDefault ? "Yes" : "")</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <input type="hidden" asp-for="RecordId" />
        <partial name="_FormToolbar" />
    </form>
</div>
