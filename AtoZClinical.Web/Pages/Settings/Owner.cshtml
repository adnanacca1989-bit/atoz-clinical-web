@page
@model AtoZClinical.Web.Pages.Settings.OwnerModel
@{
    ViewData["Title"] = "Define Owner";
    Layout = "_Layout";
}

<div class="clinical-form-page">
    <h1 class="page-title">Define Owner</h1>
    <partial name="_SettingsMenu" />
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
        <div class="clinical-form-body">
            <div class="clinical-form-left">
                <div class="row g-3">
                    <div class="col-md-2">
                        <label class="clinical-field-label">Owner ID</label>
                        <input asp-for="Input.OwnerNo" class="clinical-field" readonly />
                    </div>
                    <div class="col-md-5">
                        <label class="clinical-field-label">Owner Name *</label>
                        <input asp-for="Input.Name" class="clinical-field" />
                    </div>
                    <div class="col-md-3">
                        <label class="clinical-field-label">Phone</label>
                        <input asp-for="Input.Phone" class="clinical-field" />
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <div class="form-check mb-2">
                            <input asp-for="Input.IsActive" class="form-check-input" type="checkbox" />
                            <label class="form-check-label" asp-for="Input.IsActive">Active</label>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <label class="clinical-field-label">Email</label>
                        <input asp-for="Input.Email" class="clinical-field" type="email" />
                    </div>
                    <div class="col-md-8">
                        <label class="clinical-field-label">Notes</label>
                        <input asp-for="Input.Notes" class="clinical-field" />
                    </div>
                </div>
            </div>
            <div class="clinical-form-right">
                <div class="record-transaction-header">Record Transaction</div>
                <div class="record-transaction-status">@Model.StatusText</div>
                <div class="p-2">
                    <input id="searchBox" name="Search" value="@Model.Search" class="clinical-field mb-2" placeholder="Search..." />
                </div>
                <div class="clinical-record-grid">
                    <table>
                        <thead><tr><th>ID</th><th>Name</th><th>Phone</th><th>Email</th></tr></thead>
                        <tbody>
                        @foreach (var r in Model.Records)
                        {
                            <tr class="@(Model.RecordId == r.Id ? "selected" : "")" onclick="location.href='?RecordId=@r.Id'">
                                <td>@r.OwnerNo</td>
                                <td>@r.Name</td>
                                <td>@r.Phone</td>
                                <td>@r.Email</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <input type="hidden" asp-for="RecordId" />
        <partial name="_FormToolbar" />
    </form>
</div>
