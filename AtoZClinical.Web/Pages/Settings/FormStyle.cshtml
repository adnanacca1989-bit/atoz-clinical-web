@page
@model AtoZClinical.Web.Pages.Settings.FormStyleModel
@{
    ViewData["Title"] = "Style Forms";
    Layout = "_Layout";
}

<h2 class="atz-section-title">Style Forms</h2>
<partial name="_SettingsMenu" />

@if (Model.StatusMessage is string msg)
{
    <div class="alert alert-success">@msg</div>
}

<form method="post" class="atz-card p-4" style="max-width: 560px;">
    <div class="row g-3">
        <div class="col-md-6">
            <label class="clinical-field-label">Form Layout</label>
            <select asp-for="FormStyle" class="clinical-field">
                @foreach (var s in FormStyleModel.Styles)
                {
                    <option value="@s">@s</option>
                }
            </select>
        </div>
        <div class="col-md-6">
            <label class="clinical-field-label">Primary Color</label>
            <input asp-for="PrimaryColor" class="clinical-field" type="color" />
        </div>
    </div>
    <div class="small text-muted mt-2">Compact reduces spacing; Large increases field size.</div>
    <button type="submit" class="btn btn-atz-primary mt-3">Save</button>
</form>
