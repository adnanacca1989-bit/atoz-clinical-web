@page
@model AtoZClinical.Web.Pages.Settings.ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
    Layout = "_Layout";
}

<h2 class="atz-section-title">Change Password</h2>
<partial name="_SettingsMenu" />

@if (Model.StatusMessage is string msg)
{
    <div class="alert alert-success">@msg</div>
}

<form method="post" class="atz-card p-4" style="max-width: 420px;">
    <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
    <div class="mb-3">
        <label class="clinical-field-label">Current Password</label>
        <input asp-for="CurrentPassword" class="clinical-field" type="password" autocomplete="current-password" />
    </div>
    <div class="mb-3">
        <label class="clinical-field-label">New Password</label>
        <input asp-for="NewPassword" class="clinical-field" type="password" autocomplete="new-password" />
    </div>
    <div class="mb-3">
        <label class="clinical-field-label">Confirm New Password</label>
        <input asp-for="ConfirmPassword" class="clinical-field" type="password" autocomplete="new-password" />
    </div>
    <button type="submit" class="btn btn-atz-primary">Change Password</button>
</form>
