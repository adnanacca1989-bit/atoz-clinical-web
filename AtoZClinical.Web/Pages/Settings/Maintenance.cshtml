@page
@model AtoZClinical.Web.Pages.Settings.MaintenanceModel
@{
    ViewData["Title"] = "Maintenance";
    Layout = "_Layout";
}

<h2 class="atz-section-title">Maintenance</h2>
<partial name="_SettingsMenu" />

@if (Model.StatusMessage is string msg)
{
    <div class="alert alert-success">@msg</div>
}

<form method="post" class="atz-card p-4 mb-4" style="max-width: 560px;">
    <div class="form-check mb-3">
        <input asp-for="MaintenanceMode" class="form-check-input" type="checkbox" />
        <label class="form-check-label" asp-for="MaintenanceMode">Enable maintenance mode</label>
    </div>
    <label class="clinical-field-label">Maintenance Notes</label>
    <textarea asp-for="MaintenanceNotes" class="clinical-field" rows="3" placeholder="Message shown to staff during maintenance..."></textarea>
    <button type="submit" class="btn btn-atz-primary mt-3">Save</button>
</form>

<div class="atz-card p-4" style="max-width: 560px;">
    <h5 class="text-primary">Data Backup</h5>
    <p class="text-muted small">Export clinic data to Excel for backup or migration.</p>
    <a class="btn btn-outline-primary" asp-page="/Admin/Backup">Open Data Backup</a>
</div>
