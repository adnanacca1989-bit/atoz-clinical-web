@page
@model AtoZClinical.Web.Pages.ServiceIncomes.IndexModel
@{
    ViewData["Title"] = "Service Income";
    Layout = "_Layout";
}

<div class="clinical-form-page">
    <h1 class="page-title">Service Income</h1>
    <form method="post">
        <div class="clinical-form-body">
            <div class="clinical-form-left">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="clinical-field-label">Service No</label>
                        <input asp-for="Input.ServiceNo" class="clinical-field" readonly />
                    </div>
                    <div class="col-md-8">
                        <label class="clinical-field-label">Name</label>
                        <input asp-for="Input.Name" class="clinical-field" />
                    </div>
                    <div class="col-md-6">
                        <label class="clinical-field-label">Account Name</label>
                        <select asp-for="Input.AccountName" class="clinical-field">
                            @foreach (var acct in Model.IncomeAccounts)
                            {
                                <option value="@acct.Name">@acct.Name</option>
                            }
                            @if (!string.IsNullOrWhiteSpace(Model.Input.AccountName) &&
                                 !Model.IncomeAccounts.Any(a => a.Name == Model.Input.AccountName))
                            {
                                <option value="@Model.Input.AccountName" selected>@Model.Input.AccountName</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="clinical-field-label">Fee</label>
                        <input asp-for="Input.Fee" class="clinical-field" type="number" step="0.01" />
                    </div>
                </div>
            </div>
            <div class="clinical-form-right">
                <div class="record-transaction-header">Record Transaction</div>
                <div class="record-transaction-status">@Model.StatusText</div>
                <div class="p-2">
                    <input id="searchBox" name="Search" value="@Model.Search" class="clinical-field mb-2" placeholder="Search..." />
                </div>
                <div class="clinical-record-grid">
                    <table>
                        <thead><tr><th>Servic...</th><th>Name</th><th>Account</th></tr></thead>
                        <tbody>
                        @foreach (var r in Model.Records)
                        {
                            <tr class="@(Model.RecordId == r.Id ? "selected" : "")" onclick="location.href='?RecordId=@r.Id'">
                                <td>@r.ServiceNo</td>
                                <td>@r.Name</td>
                                <td>@r.AccountName</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <input type="hidden" asp-for="RecordId" />
        <partial name="_FormToolbar" />
        <div class="clinical-form-footer">
            <span>Created By: @Model.UserName</span>
            <span>Last Updated By: @Model.UserName</span>
        </div>
    </form>
</div>
