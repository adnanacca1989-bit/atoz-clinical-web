@page
@model AtoZClinical.Web.Pages.Portal.IndexModel
@{
    ViewData["Title"] = "My health";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Patient portal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/clinical.css" asp-append-version="true" />
</head>
<body class="p-3">
    <div class="container" style="max-width:900px">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold mb-0" style="color:#0b4f8a">Hello, @Model.Patient?.FirstName</h2>
                <p class="text-muted mb-0">Patient no. @Model.Patient?.PatientNo</p>
            </div>
            <a asp-page="/Portal/Logout" class="btn btn-outline-secondary btn-sm">Sign out</a>
        </div>

        <div class="mb-3">
            <a asp-page="/Portal/Book" class="btn btn-atz-primary btn-sm">Book appointment</a>
        </div>

        <div class="atz-card p-3 mb-4">
            <h5>Upcoming appointments</h5>
            @if (Model.UpcomingAppointments.Count == 0)
            {
                <p class="text-muted mb-0">No upcoming appointments.</p>
            }
            else
            {
                <table class="table table-sm mb-0">
                    <thead><tr><th>Date</th><th>Time</th><th>Doctor</th><th>Status</th></tr></thead>
                    <tbody>
                    @foreach (var a in Model.UpcomingAppointments)
                    {
                        <tr>
                            <td>@a.AppointmentDate.ToString("d")</td>
                            <td>@a.StartTime.ToString(@"hh\:mm")</td>
                            <td>@a.DoctorName</td>
                            <td>@a.Status</td>
                        </tr>
                    }
                    </tbody>
                </table>
            }
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <div class="atz-card p-3 h-100">
                    <h5>Recent prescriptions</h5>
                    @if (Model.RecentPrescriptions.Count == 0)
                    {
                        <p class="text-muted mb-0">None on file.</p>
                    }
                    else
                    {
                        <ul class="mb-0">
                            @foreach (var rx in Model.RecentPrescriptions)
                            {
                                <li>@rx.DatePrescription.ToString("d") — @rx.DoctorName</li>
                            }
                        </ul>
                    }
                </div>
            </div>
            <div class="col-md-6">
                <div class="atz-card p-3 h-100">
                    <h5>Recent bills</h5>
                    @if (Model.RecentInvoices.Count == 0)
                    {
                        <p class="text-muted mb-0">None on file.</p>
                    }
                    else
                    {
                        <ul class="mb-0">
                            @foreach (var inv in Model.RecentInvoices)
                            {
                                <li>@inv.InvoiceDate.ToString("d") — @inv.TotalAmount.ToString("N2") (@inv.PaymentStatus)</li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
    </div>
</body>
</html>
