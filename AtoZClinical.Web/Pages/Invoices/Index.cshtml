@page
@model AtoZClinical.Web.Pages.Invoices.IndexModel
@{
    ViewData["Title"] = "Invoice / Billing";
    ViewData["FormHint"] = "Click Patient Name to load lab, radiology, pharmacy charges and doctor consultation fee. Use Add Service below for registered services, or type any charge description.";
    Layout = "_Layout";
}

<div class="clinical-form-page clinical-standard-form invoice-form-page">
    <h1 class="page-title">Invoice / Billing</h1>
    <div asp-validation-summary="All" class="validation-summary-errors"></div>
    <partial name="_ClinicalFormHint" />
    <form method="post">
        <div class="clinical-form-body">
            <div class="clinical-form-left clinical-form-scroll">
                <div class="row g-2 mb-2 clinical-form-header">
                    <div class="col-md-2">
                        <label class="clinical-field-label">Invoice ID</label>
                        <input asp-for="Input.InvoiceNo" class="clinical-field" readonly />
                    </div>
                    <div class="col-md-2">
                        <label class="clinical-field-label">Invoice Date</label>
                        <input asp-for="Input.InvoiceDate" class="clinical-field" type="date" />
                    </div>
                    <div class="col-md-3">
                        <label class="clinical-field-label">Patient Name</label>
                        <input asp-for="Input.PatientName" id="invoicePatientNameInput" class="clinical-field doctor-picker-field" readonly placeholder="Click to select patient..." />
                    </div>
                    <div class="col-md-2">
                        <label class="clinical-field-label">Patient Barcode</label>
                        <input asp-for="Input.PatientId" class="clinical-field" readonly />
                    </div>
                    <div class="col-md-1">
                        <label class="clinical-field-label">Age</label>
                        <input asp-for="Input.Age" class="clinical-field" type="number" readonly />
                    </div>
                    <div class="col-md-2">
                        <label class="clinical-field-label">Gender</label>
                        <input asp-for="Input.Gender" class="clinical-field" readonly />
                    </div>
                    <div class="col-md-2">
                        <label class="clinical-field-label">Phone</label>
                        <input asp-for="Input.Phone" class="clinical-field" readonly />
                    </div>
                    <div class="col-md-2">
                        <label class="clinical-field-label">City</label>
                        <input asp-for="Input.City" class="clinical-field" readonly />
                    </div>
                    <div class="col-md-4">
                        <label class="clinical-field-label">Doctor Name</label>
                        <input asp-for="Input.DoctorName" class="clinical-field" readonly />
                    </div>
                    <div class="col-md-4">
                        <label class="clinical-field-label">Specialty</label>
                        <input asp-for="Input.Specialty" class="clinical-field" readonly />
                    </div>
                    <div class="col-md-4">
                        <label class="clinical-field-label">Invoice Status</label>
                        <input asp-for="Input.PaymentStatus" class="clinical-field" />
                    </div>
                </div>
                <div class="clinical-form-grid-area invoice-lines-area">
                <div class="section-caption">Invoice Lines</div>
                <div class="line-toolbar invoice-line-toolbar">
                    <select id="invoiceQuickServicePick" class="clinical-field" title="Registered services">
                        <option value="">— Pick registered service —</option>
                        @foreach (var s in Model.Services)
                        {
                            <option value="@s.Name" data-fee="@s.Fee" data-no="@s.ServiceNo">@s.Name (@s.Fee.ToString("N0"))</option>
                        }
                    </select>
                    <button type="button" id="invoiceQuickServiceAdd" class="btn-form btn-form-sm">+ Add Service Line</button>
                    <span class="line-toolbar-hint">Or type a description directly in each row (e.g. Lab #1: CBC).</span>
                </div>
                <div class="line-grid-scroll clinical-line-grid-scroll invoice-line-grid-scroll">
                <table class="line-grid invoice-line-grid clinical-line-grid">
                    <thead><tr><th class="col-no">No</th><th class="col-item">Service / Charge</th><th class="col-qty">QTY</th><th class="col-rate">Rate</th><th class="col-total">Total</th><th class="col-del">Del</th></tr></thead>
                    <tbody>
                    @for (var i = 0; i < Model.Lines.Count; i++)
                    {
                        <tr class="invoice-line">
                            <td><input asp-for="Lines[i].LineNo" readonly /></td>
                            <td class="col-item">
                                <input asp-for="Lines[i].ServiceName" class="clinical-field invoice-service-name" placeholder="Service / charge description" list="invoiceServiceList" />
                            </td>
                            <td class="col-qty"><input asp-for="Lines[i].Qty" type="number" min="1" /></td>
                            <td class="col-rate"><input asp-for="Lines[i].UnitFee" type="number" step="0.01" /></td>
                            <td class="col-total"><input value="@(Model.Lines[i].LineTotal.ToString("N2"))" readonly class="invoice-line-total" /></td>
                            <td class="col-del text-center"><button type="button" class="btn-form delete-line-btn" title="Delete line">🗑</button></td>
                        </tr>
                    }
                    </tbody>
                </table>
                </div>
                </div>
                <div class="clinical-form-totals-section">
                <div class="section-caption">Invoice Totals &amp; Payment</div>
                <div class="form-summary-panel invoice-summary-panel">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="clinical-field-label">Total Invoice Amount</label>
                        <input id="invoiceSubTotal" value="@Model.LineSubTotal.ToString("N2")" class="clinical-field invoice-summary-field" readonly />
                    </div>
                    <div class="col-md-4">
                        <label class="clinical-field-label">Discount</label>
                        <input asp-for="Input.Discount" id="invoiceDiscount" class="clinical-field invoice-summary-field" type="number" step="0.01" />
                    </div>
                    <div class="col-md-4">
                        <label class="clinical-field-label">Net Invoice Amount</label>
                        <input id="invoiceNetAmount" value="@Model.NetAmount.ToString("N2")" class="clinical-field invoice-summary-field invoice-net-field" readonly />
                    </div>
                </div>
                <div class="row g-3 mt-1">
                    <div class="col-md-4">
                        <label class="clinical-field-label">Cash Paid</label>
                        <input asp-for="Input.AmountPaid" id="invoiceAmountPaid" class="clinical-field invoice-summary-field" type="number" step="0.01" />
                    </div>
                    <div class="col-md-4">
                        <label class="clinical-field-label">Payment Method</label>
                        <select asp-for="Input.PaymentMethod" class="clinical-field invoice-summary-field" asp-items="@(new SelectList(AtoZClinical.Infrastructure.Services.ClinicLookup.PaymentMethods))"></select>
                    </div>
                    <div class="col-md-4">
                        <label class="clinical-field-label">Balance Due</label>
                        <input id="invoiceBalance" value="@Model.Balance.ToString("N2")" class="clinical-field invoice-summary-field invoice-balance-field" readonly />
                    </div>
                </div>
                </div>
                </div>
            </div>
            <datalist id="invoiceServiceList">
                @foreach (var s in Model.Services)
                {
                    <option value="@s.Name"></option>
                }
            </datalist>
            <div class="clinical-form-right">
                <div class="record-transaction-header">Record Transaction</div>
                <div class="record-transaction-status">@Model.StatusText</div>
                <div class="p-2">
                    <input id="searchBox" name="Search" value="@Model.Search" class="clinical-field mb-2" placeholder="Search..." />
                </div>
                <div class="clinical-record-grid">
                    <table>
                        <thead><tr><th>Invoice No</th><th>Patient</th><th>Doctor</th></tr></thead>
                        <tbody>
                        @foreach (var r in Model.Records)
                        {
                            <tr class="@(Model.RecordId == r.Id ? "selected" : "")" onclick="location.href='?RecordId=@r.Id'">
                                <td>@r.InvoiceNo</td>
                                <td>@r.PatientName</td>
                                <td>@r.DoctorName</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <input type="hidden" asp-for="RecordId" />
        <partial name="_FormToolbar" />
        <div class="clinical-form-footer">
            <span>Created By: @Model.UserName</span>
            <span>Last Updated By: @Model.UserName</span>
        </div>
    </form>
</div>

<partial name="_PatientSelectModal" />

@section Scripts {
    <script src="~/js/patient-picker.js" asp-append-version="true"></script>
    <script src="~/js/clinical-line-grid.js" asp-append-version="true"></script>
    <script src="~/js/invoice-billing.js" asp-append-version="true"></script>
}
