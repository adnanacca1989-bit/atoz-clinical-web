@page
@model AtoZClinical.Web.Pages.Dashboard.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<h2 class="atz-section-title">Dashboard</h2>
<p class="text-muted">@Model.ClinicName</p>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="atz-card p-3 stat-card">
            <div class="text-muted small">Patients</div>
            <div class="display-6">@Model.PatientCount</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="atz-card p-3 stat-card">
            <div class="text-muted small">Today's Appointments</div>
            <div class="display-6">@Model.TodayAppointments</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="atz-card p-3 stat-card">
            <div class="text-muted small">Upcoming (7 days)</div>
            <div class="display-6">@Model.UpcomingAppointments</div>
        </div>
    </div>
</div>

<div class="atz-card p-3">
    <h5 class="mb-3">All Forms</h5>
    <p class="text-muted small mb-3">Open any clinic form from here, or use the sidebar on the left.</p>

    @foreach (var group in Model.FormGroups)
    {
        <div class="mb-3">
            <div class="fw-semibold text-secondary small text-uppercase mb-2">@group.Title</div>
            <div class="d-flex flex-wrap gap-2">
                @foreach (var form in group.Forms)
                {
                    <a class="btn btn-outline-primary btn-sm" asp-page="@form.Page">@form.Label</a>
                }
            </div>
        </div>
    }
</div>
